<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <SolidColorBrush x:Key="FlareTextBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="FlareMutedTextBrush" Color="#A7B2C2" />
    <SolidColorBrush x:Key="FlareAccentBrush" Color="#99CC00" />
    <SolidColorBrush x:Key="FlareAccentTextBrush" Color="#102000" />
    <SolidColorBrush x:Key="FlarePrimaryGreenBrush" Color="#D999CC00" />
    <SolidColorBrush x:Key="FlarePrimaryGreenHoverBrush" Color="#E6AADD14" />
    <SolidColorBrush x:Key="FlarePrimaryGreenPressedBrush" Color="#C985B300" />
    <SolidColorBrush x:Key="FlarePrimaryGreenBorderBrush" Color="#A9C957" />

    <LinearGradientBrush x:Key="FlareDarkBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F2121C2D" Offset="0.0"/>
        <GradientStop Color="#E60A101C" Offset="1.0"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="FlareBorderBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1AFFFFFF" Offset="0.0"/>
        <GradientStop Color="#0DFFFFFF" Offset="1.0"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="FlareHeaderBrush" Color="#40000000" />
    <LinearGradientBrush x:Key="GlassBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F2121C2D" Offset="0.0"/>
        <GradientStop Color="#E60A101C" Offset="1.0"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="GlassBorderBrush" Color="#30405A" />
    <SolidColorBrush x:Key="GlassHeaderBrush" Color="#F70F1722" />
    <LinearGradientBrush x:Key="GlassCardBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#26FFFFFF" Offset="0.0"/>
        <GradientStop Color="#0DFFFFFF" Offset="1.0"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="GlassCardAltBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#10FFFFFF" Offset="0.0"/>
        <GradientStop Color="#04FFFFFF" Offset="1.0"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="GlassInputBrush" Color="#14FFFFFF" />

    <LinearGradientBrush x:Key="FlareCardBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#26FFFFFF" Offset="0.0"/>
        <GradientStop Color="#0DFFFFFF" Offset="1.0"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="FlareCardAltBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#10FFFFFF" Offset="0.0"/>
        <GradientStop Color="#04FFFFFF" Offset="1.0"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="GlassPopupBrush" Color="#FA1E293B" />
    <SolidColorBrush x:Key="PopupTextBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="DropdownPopupBrush" Color="#F41E293B" />
    <SolidColorBrush x:Key="DropdownInputBrush" Color="#243241" />
    <SolidColorBrush x:Key="DropdownOptionBrush" Color="#2B394A" />
    <SolidColorBrush x:Key="DropdownOptionHoverBrush" Color="#34465C" />
    <SolidColorBrush x:Key="DropdownOptionBorderBrush" Color="#52677F" />
    <SolidColorBrush x:Key="DropdownTextBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="DropdownMutedTextBrush" Color="#CBD5E1" />

    <SolidColorBrush x:Key="FlareInputBrush" Color="#14FFFFFF" /> 
    <SolidColorBrush x:Key="FlareButtonBrush" Color="#26FFFFFF" />
    <SolidColorBrush x:Key="GlassButtonHoverBrush" Color="#40FFFFFF" /> 
    <SolidColorBrush x:Key="FlareButtonBorderBrush" Color="#20FFFFFF" />
    
    <SolidColorBrush x:Key="FlareChipBrush" Color="#22FFFFFF" />
    <SolidColorBrush x:Key="FlareChipBorderBrush" Color="#4DFFFFFF" />

    <Style TargetType="Window">
        <Setter Property="Foreground" Value="{DynamicResource FlareTextBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource FlareTextBrush}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{DynamicResource FlareTextBrush}" />
    </Style>

    <Style x:Key="MutedText" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="Foreground" Value="{DynamicResource FlareMutedTextBrush}" />
    </Style>

    <Style x:Key="GlassCard" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource GlassCardBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="18" />
    </Style>

    <Style x:Key="Card" TargetType="Border" BasedOn="{StaticResource GlassCard}" />

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource FlareInputBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FlareTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FlareButtonBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="CaretBrush" Value="{DynamicResource FlareTextBrush}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource FlareAccentBrush}" />
        <Setter Property="SelectionTextBrush" Value="{DynamicResource FlareAccentTextBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource FlareButtonBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FlareTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FlareButtonBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource GlassButtonHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{DynamicResource FlarePrimaryGreenBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FlareAccentTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FlarePrimaryGreenBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource FlarePrimaryGreenHoverBrush}" />
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource FlarePrimaryGreenPressedBrush}" />
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ToggleButton">
        <Setter Property="Background" Value="{DynamicResource FlareButtonBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FlareTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FlareButtonBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="ToggleBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource GlassButtonHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource GlassButtonHoverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ModeToggleStyle" TargetType="ToggleButton">
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid>
                        <Border x:Name="SliderTrack" Background="{DynamicResource FlareButtonBrush}" BorderBrush="{DynamicResource FlareButtonBorderBrush}" BorderThickness="1" CornerRadius="12" />
                        <Border x:Name="SliderThumb" Width="18" Height="18" HorizontalAlignment="Left" Margin="3,0,3,0" Background="#F8FAFC" CornerRadius="9">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.2" Direction="270" Color="Black"/>
                            </Border.Effect>
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="ThumbTransform" X="0" />
                            </Border.RenderTransform>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="SliderTrack" Property="Background" Value="{DynamicResource FlareAccentBrush}" />
                            <Setter TargetName="SliderTrack" Property="BorderBrush" Value="Transparent" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="SliderThumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="21" Duration="0:0:0.18" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="SliderThumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.18" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource FlareInputBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource FlareTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,6" />
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource FlareTextBrush}" />
        <Setter Property="Padding" Value="8,5" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource FlareTextBrush}" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="InvisibleScrollRepeatButton" TargetType="{x:Type RepeatButton}">
        <Setter Property="OverridesDefaultStyle" Value="True" /><Setter Property="Focusable" Value="False" /><Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="{x:Type RepeatButton}"><Border Background="Transparent" /></ControlTemplate></Setter.Value></Setter>
    </Style>
    <Style x:Key="IntegratedScrollThumb" TargetType="{x:Type Thumb}">
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}"><Border x:Name="ThumbBorder" Width="5" Margin="1,2" CornerRadius="3" Background="{DynamicResource GlassButtonHoverBrush}" Opacity="0.6" />
                <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ThumbBorder" Property="Opacity" Value="1.0" /></Trigger></ControlTemplate.Triggers></ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="Width" Value="8" /><Setter Property="MinWidth" Value="8" /><Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollBar}">
                    <Grid Background="Transparent" Width="8" Margin="2,0,0,0">
                        <Track x:Name="PART_Track" IsDirectionReversed="True"><Track.DecreaseRepeatButton><RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Style="{StaticResource InvisibleScrollRepeatButton}" /></Track.DecreaseRepeatButton><Track.Thumb><Thumb Style="{StaticResource IntegratedScrollThumb}" /></Track.Thumb><Track.IncreaseRepeatButton><RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Style="{StaticResource InvisibleScrollRepeatButton}" /></Track.IncreaseRepeatButton></Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>




