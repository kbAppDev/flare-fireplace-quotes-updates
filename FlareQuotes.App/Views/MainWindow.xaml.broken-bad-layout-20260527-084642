<Window x:Class="FlareQuotes.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Flare Fireplaces - Quotes" Width="1420" Height="880" MinWidth="1100" MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        MouseLeftButtonDown="Window_MouseDown">
    
    <Border CornerRadius="20" Background="{DynamicResource GlassBackgroundBrush}" BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1.5" Margin="30">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="15" Opacity="0.4" Direction="270" Color="Black" />
        </Border.Effect>
        
        <Grid Background="Transparent" PreviewMouseDown="Root_PreviewMouseDown">
            <Grid.RowDefinitions>
                <RowDefinition Height="76" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="18,18,0,0" Background="{DynamicResource GlassHeaderBrush}" BorderBrush="{DynamicResource GlassCardBorderBrush}" BorderThickness="0,0,0,1" Padding="22,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image x:Name="HeaderLogoImage" Source="/Assets/header_logo-dark.png" Width="210" Stretch="Uniform" Margin="0,0,18,0" />
                        <StackPanel>
                            <TextBlock Text="Flare Fireplaces - Quotes" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource FlareTextBrush}"/>
                            <TextBlock Text="v1.2.2" Style="{StaticResource MutedText}" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding GmailStatusText}" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,18,0" />
                        
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,0">
                            <TextBlock x:Name="ThemeLabelText" Text="Dark Mode" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold" Style="{StaticResource MutedText}"/>
                            <ToggleButton x:Name="ThemeToggleButton" Style="{StaticResource ModeToggleStyle}" IsChecked="True" Checked="ThemeToggleButton_Checked" Unchecked="ThemeToggleButton_Unchecked" />
                        </StackPanel>
                        
                        <Button Content="Settings" Width="104" Click="SettingsButton_Click" />
                        <Border Width="1" Background="{DynamicResource GlassBorderBrush}" Margin="16,4" />
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Width="14" Height="14" Margin="0,0,8,0" Click="MinimizeButton_Click" Cursor="Hand" ToolTip="Minimize"><Button.Template><ControlTemplate TargetType="Button"><Border Background="#FFBD2E" CornerRadius="7"/></ControlTemplate></Button.Template></Button>
                            <Button Width="14" Height="14" Margin="0,0,8,0" Click="MaximizeButton_Click" Cursor="Hand" ToolTip="Maximize"><Button.Template><ControlTemplate TargetType="Button"><Border Background="#27C93F" CornerRadius="7"/></ControlTemplate></Button.Template></Button>
                            <Button Width="14" Height="14" Click="CloseButton_Click" Cursor="Hand" ToolTip="Close"><Button.Template><ControlTemplate TargetType="Button"><Border Background="#FF5F56" CornerRadius="7"/></ControlTemplate></Button.Template></Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="1.55*" />
                    <ColumnDefinition Width="1.0*" />
                </Grid.ColumnDefinitions>

                                <!-- StageResponsivePasteCard -->
                <Border Grid.Column="0">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource GlassCard}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding WorkflowStage}" Value="PdfPreview">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding WorkflowStage}" Value="SpecLinks">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Text="1. Paste Request" FontSize="20" FontWeight="SemiBold" />
                            <TextBlock Text="Paste the customer request, then auto-fill review fields." Style="{StaticResource MutedText}" Margin="0,4,0,14" />
                        </StackPanel>
                        <TextBox Grid.Row="1" Text="{Binding RawRequest, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,14,0,0">
                            <Button Content="Auto-Fill" Command="{Binding AutoFillCommand}" Style="{StaticResource PrimaryButton}" Width="118" Margin="0,0,10,0" />
                            <Button Content="New Quote" Command="{Binding ClearCommand}" Width="120" />
                            <Button Content="Recall Quote" Command="{Binding RecallLastQuoteCommand}" Width="126" Margin="8,0,0,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CanRecallLastQuote}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                                <!-- StageResponsiveWorkflowCard -->
                <Border>
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource GlassCard}">
                            <Setter Property="Grid.Column" Value="1" />
                            <Setter Property="Grid.ColumnSpan" Value="1" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding WorkflowStage}" Value="PdfPreview">
                                    <Setter Property="Grid.Column" Value="0" />
                                    <Setter Property="Grid.ColumnSpan" Value="3" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding WorkflowStage}" Value="SpecLinks">
                                    <Setter Property="Grid.Column" Value="0" />
                                    <Setter Property="Grid.ColumnSpan" Value="3" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WorkflowStage}" Value="Review">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0">
                                <TextBlock Text="2. Review" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="Review fields, selections, and fireplaces before previewing the quote." Style="{StaticResource MutedText}" Margin="0,4,0,14" />
                            
                            <!-- ReviewStageStatusPills -->
                            <Border Background="{DynamicResource FlareCardAltBrush}" BorderBrush="{DynamicResource FlareBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="10" Margin="0,10,0,0">
                                <ItemsControl ItemsSource="{Binding StatusCards}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="3" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource FlareCardBrush}" CornerRadius="11" Padding="9,7" Margin="0,0,8,8" Height="54">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="22" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="11.5" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding Detail}" Style="{StaticResource MutedText}" FontSize="10.5" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" Margin="0,2,0,0" />
                                                    </StackPanel>

                                                    <Ellipse Grid.Column="1" Width="13" Height="13" Fill="{Binding IndicatorFill}" Stroke="{DynamicResource FlareBorderBrush}" StrokeThickness="1" ToolTip="{Binding StatusText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border></StackPanel>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
                                <StackPanel>
                                    <UniformGrid Columns="2" Rows="0">
                                        <StackPanel Margin="0,0,10,12"><TextBlock Text="Project" /><TextBox Text="{Binding ProjectName}" Height="56" VerticalContentAlignment="Center" Padding="14,4,14,4" /></StackPanel>
                                        <StackPanel Margin="0,0,0,12"><TextBlock Text="Name" /><TextBox Text="{Binding ClientName}" Height="56" VerticalContentAlignment="Center" Padding="14,4,14,4" /></StackPanel>
                                        <StackPanel Margin="0,0,10,12"><TextBlock Text="Email" /><TextBox Text="{Binding Email}" Height="56" VerticalContentAlignment="Center" Padding="14,4,14,4" /></StackPanel>
                                        <StackPanel Margin="0,0,0,12"><TextBlock Text="Phone" /><TextBox Text="{Binding Phone}" Height="56" VerticalContentAlignment="Center" Padding="14,4,14,4" /></StackPanel>
                                        <StackPanel Margin="0,0,10,12"><TextBlock Text="Project Address" /><TextBox Text="{Binding Postal}" Height="56" VerticalContentAlignment="Center" Padding="14,4,14,4" /></StackPanel>
                                        <StackPanel Margin="0,0,0,12"><TextBlock Text="Install Date" /><TextBox Text="{Binding InstallDate}" Height="56" VerticalContentAlignment="Center" Padding="14,4,14,4" /></StackPanel>
                                        <StackPanel Margin="0,0,10,12"><TextBlock Text="Model" /><TextBox Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}" Height="56" VerticalContentAlignment="Center" Padding="14,4,14,4" /></StackPanel>
                                        <StackPanel Margin="0,0,0,12"><TextBlock Text="Size" /><TextBox Text="{Binding Size, UpdateSourceTrigger=PropertyChanged}" Height="56" VerticalContentAlignment="Center" Padding="14,4,14,4" /></StackPanel>
                                        <StackPanel Margin="0,0,10,12"><TextBlock Text="Glass Height" /><TextBox Text="{Binding GlassHeight, UpdateSourceTrigger=PropertyChanged}" Height="56" VerticalContentAlignment="Center" Padding="14,4,14,4" /></StackPanel>
                                        <StackPanel Margin="0,0,0,12"><TextBlock Text="Location" /><TextBox Text="{Binding FireplaceLocation, UpdateSourceTrigger=PropertyChanged}" Height="56" VerticalContentAlignment="Center" Padding="14,4,14,4" /></StackPanel>
                                    </UniformGrid>

                                    

                                    
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                                                <!-- FullWidthPreviewStage -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WorkflowStage}" Value="PdfPreview">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="2. Preview Quote" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="Review the generated quote PDF. Use Open Generated PDF if the embedded preview cannot render the file." Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                            </StackPanel>

                            <Border Grid.Row="2" Background="{DynamicResource FlareCardAltBrush}" CornerRadius="14" Padding="10" BorderBrush="{DynamicResource FlareBorderBrush}" BorderThickness="1">
                                <Grid>
                                    <Border Background="White" CornerRadius="8" ClipToBounds="True">
                                        <Grid>
                                            <ContentControl x:Name="PdfPreviewHost" />
                                            <Border x:Name="PdfPreviewFallback" Background="{DynamicResource FlareCardBrush}" BorderBrush="{DynamicResource FlareBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="18">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock Text="Quote PDF generated." FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                                    <TextBlock Text="Live preview loads after the PDF is generated." Style="{StaticResource MutedText}" TextAlignment="Center" Margin="0,8,0,0" />
                                                    <TextBlock Text="Use Open Generated PDF if the preview component is unavailable." Style="{StaticResource MutedText}" TextAlignment="Center" Margin="0,4,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- FullWidthPreviewActionFooter -->
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="140" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding GeneratedPdfSummary}" Style="{StaticResource MutedText}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,12,0" />
                                <Button Grid.Column="1" Content="Back" Command="{Binding BackToReviewCommand}" Height="40" />
                                <Button Grid.Column="3" Content="Open Generated PDF" Command="{Binding OpenGeneratedPdfCommand}" Height="40" Padding="16,0" />
                                <Button Grid.Column="5" Content="Verify URLs" Command="{Binding NextToSpecLinksCommand}" Style="{StaticResource PrimaryButton}" Height="40" />
                            </Grid>
                        </Grid>
                        <!-- FullWidthSpecLinksStage -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WorkflowStage}" Value="SpecLinks">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="2. Verify URLs" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="Review the product/spec URLs before creating the Gmail draft." Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                            </StackPanel>

                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding SpecLinks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource FlareCardAltBrush}" BorderBrush="{DynamicResource FlareBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="10" Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="130" />
                                                        <ColumnDefinition Width="190" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding FireplaceCode}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Label}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                                                    <TextBox Grid.Column="2" Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}" Height="52" VerticalContentAlignment="Center" Padding="12,4,12,4" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- FullWidthSpecLinksActionFooter -->
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="180" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Specific matched URLs are preferred. Yellow/fallback URLs should be checked before drafting." Style="{StaticResource MutedText}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,12,0" />
                                <Button Grid.Column="1" Content="Back to Preview" Command="{Binding BackToPreviewCommand}" Height="40" />
                                <Button Grid.Column="3" Content="Create Gmail Draft" Command="{Binding CreateDraftCommand}" Style="{StaticResource PrimaryButton}" Height="40" />
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>

                                                <!-- StageResponsiveStatusCard -->
                <!-- SelectionsFireplacesMovedToStatusPanel -->
                <Border Grid.Column="2">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource GlassCard}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding WorkflowStage}" Value="PdfPreview">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding WorkflowStage}" Value="SpecLinks">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="3. Quote Build" FontSize="20" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MutedText}" Margin="0,4,0,0" TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,0,0,8">
<Border Background="{DynamicResource FlareCardAltBrush}" BorderBrush="{DynamicResource FlareBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="9" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="Selections" FontSize="14" FontWeight="SemiBold" />
                                            <TextBlock Text="Select features, media, and quote options." Style="{StaticResource MutedText}" Margin="0,3,0,14" TextWrapping="Wrap" />

                                            <TextBlock Text="Additional Features" FontWeight="SemiBold" Margin="0,0,0,6" />
                                            <Grid Margin="0,0,0,8">
                                                <ToggleButton x:Name="FeatureDropdownButton" Content="{Binding FeatureDropdownButtonText}" IsChecked="{Binding IsFeatureDropdownOpen, Mode=TwoWay}" HorizontalContentAlignment="Left" MinHeight="36" PreviewMouseLeftButtonDown="DropdownToggle_PreviewMouseLeftButtonDown" />
                                                <Popup x:Name="FeatureDropdownPopup" IsOpen="{Binding IsFeatureDropdownOpen, Mode=TwoWay}" PlacementTarget="{Binding ElementName=FeatureDropdownButton}" Placement="Bottom" StaysOpen="True" AllowsTransparency="True">
                                                    <Border Width="{Binding ActualWidth, ElementName=FeatureDropdownButton}" Background="{DynamicResource GlassPopupBrush}" BorderBrush="{DynamicResource FlareBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="10" Margin="0,4,0,0">
                                                        <StackPanel>
                                                            <TextBox Text="{Binding FeatureSearch, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" ToolTip="Search features" />
                                                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="140">
                                                                <ItemsControl ItemsSource="{Binding FilteredFeatureOptions}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Button Command="{Binding DataContext.ToggleFeatureCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" HorizontalContentAlignment="Stretch" Margin="0,0,0,8" Padding="10,8">
                                                                                <Grid>
                                                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="22" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                                                    <Ellipse Width="9" Height="9" Fill="#99CC00" Stroke="Transparent" StrokeThickness="0" VerticalAlignment="Center">
                                                                                        <Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding IsSelected}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Ellipse.Style>
                                                                                    </Ellipse>
                                                                                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}" VerticalAlignment="Center" />
                                                                                </Grid>
                                                                            </Button>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </ScrollViewer>
                                                            <Grid Margin="0,8,0,0">
                                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                                <Button Content="Clear" Command="{Binding ClearFeaturesCommand}" Margin="0,0,6,0" Height="36" />
                                                                <Button Grid.Column="1" Content="Done" Command="{Binding CloseFeatureDropdownCommand}" Margin="6,0,0,0" Height="36" />
                                                            </Grid>
                                                        </StackPanel>
                                                    </Border>
                                                </Popup>
                                            </Grid>

                                            <ItemsControl ItemsSource="{Binding SelectedFeatures}" Margin="0,0,0,8">
                                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{DynamicResource FlareChipBrush}" BorderBrush="{DynamicResource FlareChipBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="10,5" Margin="0,0,8,8">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Ellipse Width="8" Height="8" Fill="#99CC00" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                                <TextBlock Text="{Binding DisplayName}" />
                                                                <Button Content="×" Command="{Binding DataContext.RemoveFeatureCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Width="24" Padding="0" Margin="8,0,0,0" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock Text="Classic Media" FontWeight="SemiBold" Margin="0,2,0,6" />
                                            <Grid Margin="0,0,0,8">
                                                <ToggleButton x:Name="ClassicMediaDropdownButton" Content="{Binding ClassicMediaDropdownButtonText}" IsChecked="{Binding IsClassicMediaDropdownOpen, Mode=TwoWay}" HorizontalContentAlignment="Left" MinHeight="36" PreviewMouseLeftButtonDown="DropdownToggle_PreviewMouseLeftButtonDown" />
                                                <Popup x:Name="ClassicMediaDropdownPopup" IsOpen="{Binding IsClassicMediaDropdownOpen, Mode=TwoWay}" PlacementTarget="{Binding ElementName=ClassicMediaDropdownButton}" Placement="Bottom" StaysOpen="True" AllowsTransparency="True">
                                                    <Border Width="{Binding ActualWidth, ElementName=ClassicMediaDropdownButton}" Background="{DynamicResource GlassPopupBrush}" BorderBrush="{DynamicResource FlareBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="10" Margin="0,4,0,0">
                                                        <StackPanel>
                                                            <TextBox Text="{Binding ClassicMediaSearch, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" ToolTip="Search classic media" />
                                                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="140">
                                                                <ItemsControl ItemsSource="{Binding FilteredClassicMediaOptions}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Button Command="{Binding DataContext.SelectClassicMediaCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" HorizontalContentAlignment="Stretch" Margin="0,0,0,8" Padding="10,8">
                                                                                <Grid>
                                                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="22" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                                                    <Ellipse Width="9" Height="9" Fill="#99CC00" Stroke="Transparent" StrokeThickness="0" VerticalAlignment="Center">
                                                                                        <Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding IsSelected}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Ellipse.Style>
                                                                                    </Ellipse>
                                                                                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}" VerticalAlignment="Center" />
                                                                                </Grid>
                                                                            </Button>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </ScrollViewer>
                                                            <Grid Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                                <Button Content="Clear" Command="{Binding ClearClassicMediaCommand}" Margin="0,0,6,0" Height="36" />
                                                                <Button Grid.Column="1" Content="Done" Command="{Binding CloseClassicMediaDropdownCommand}" Margin="6,0,0,0" Height="36" />
                                                            </Grid>
                                                        </StackPanel>
                                                    </Border>
                                                </Popup>
                                            </Grid>

                                            <TextBlock Text="Premium Media" FontWeight="SemiBold" Margin="0,0,0,6" />
                                            <Grid Margin="0,0,0,8">
                                                <ToggleButton x:Name="PremiumMediaDropdownButton" Content="{Binding PremiumMediaDropdownButtonText}" IsChecked="{Binding IsPremiumMediaDropdownOpen, Mode=TwoWay}" HorizontalContentAlignment="Left" MinHeight="36" PreviewMouseLeftButtonDown="DropdownToggle_PreviewMouseLeftButtonDown" />
                                                <Popup x:Name="PremiumMediaDropdownPopup" IsOpen="{Binding IsPremiumMediaDropdownOpen, Mode=TwoWay}" PlacementTarget="{Binding ElementName=PremiumMediaDropdownButton}" Placement="Bottom" StaysOpen="True" AllowsTransparency="True">
                                                    <Border Width="{Binding ActualWidth, ElementName=PremiumMediaDropdownButton}" Background="{DynamicResource GlassPopupBrush}" BorderBrush="{DynamicResource FlareBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="10" Margin="0,4,0,0">
                                                        <StackPanel>
                                                            <TextBox Text="{Binding PremiumMediaSearch, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" ToolTip="Search premium media" />
                                                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="140">
                                                                <ItemsControl ItemsSource="{Binding FilteredPremiumMediaOptions}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Button Command="{Binding DataContext.TogglePremiumMediaCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" HorizontalContentAlignment="Stretch" Margin="0,0,0,8" Padding="10,8">
                                                                                <Grid>
                                                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="22" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                                                    <Ellipse Width="9" Height="9" Fill="#99CC00" Stroke="Transparent" StrokeThickness="0" VerticalAlignment="Center">
                                                                                        <Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding IsSelected}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Ellipse.Style>
                                                                                    </Ellipse>
                                                                                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}" VerticalAlignment="Center" />
                                                                                </Grid>
                                                                            </Button>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </ScrollViewer>
                                                            <Grid Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                                <Button Content="Clear" Command="{Binding ClearPremiumMediaCommand}" Margin="0,0,6,0" Height="36" />
                                                                <Button Grid.Column="1" Content="Done" Command="{Binding ClosePremiumMediaDropdownCommand}" Margin="6,0,0,0" Height="36" />
                                                            </Grid>
                                                        </StackPanel>
                                                    </Border>
                                                </Popup>
                                            </Grid>
                                            <ItemsControl ItemsSource="{Binding SelectedPremiumMedia}" Margin="0,0,0,8"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><Border Background="{DynamicResource FlareChipBrush}" BorderBrush="{DynamicResource FlareChipBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="10,5" Margin="0,0,8,8"><StackPanel Orientation="Horizontal"><Ellipse Width="8" Height="8" Fill="#99CC00" VerticalAlignment="Center" Margin="0,0,8,0" /><TextBlock Text="{Binding DisplayName}" /><Button Content="×" Command="{Binding DataContext.RemovePremiumMediaCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Width="24" Padding="0" Margin="8,0,0,0" /></StackPanel></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                                        </StackPanel>
                                    </Border>

<Border Background="{DynamicResource FlareCardAltBrush}" BorderBrush="{DynamicResource FlareBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="9" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="Fireplaces" FontSize="14" FontWeight="SemiBold" />
                                            <TextBlock Text="Lead time and multi-fireplace quote controls." Style="{StaticResource MutedText}" Margin="0,3,0,12" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding CurrentFireplaceLabel}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                            <TextBlock Text="Lead Time" FontWeight="SemiBold" Margin="0,8,0,6" />
                                            <Grid Margin="0,0,0,10">
                                                <ToggleButton x:Name="LeadTimeDropdownButton" Content="{Binding LeadTimeDropdownButtonText}" IsChecked="{Binding IsLeadTimeDropdownOpen, Mode=TwoWay}" HorizontalContentAlignment="Left" MinHeight="36" PreviewMouseLeftButtonDown="DropdownToggle_PreviewMouseLeftButtonDown" />
                                                <Popup x:Name="LeadTimeDropdownPopup" IsOpen="{Binding IsLeadTimeDropdownOpen, Mode=TwoWay}" PlacementTarget="{Binding ElementName=LeadTimeDropdownButton}" Placement="Bottom" StaysOpen="True" AllowsTransparency="True">
                                                    <Border Width="{Binding ActualWidth, ElementName=LeadTimeDropdownButton}" Background="{DynamicResource GlassPopupBrush}" BorderBrush="{DynamicResource FlareBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="10" Margin="0,4,0,0">
                                                        <StackPanel>
                                                            <ItemsControl ItemsSource="{Binding LeadTimePresets}"><ItemsControl.ItemTemplate><DataTemplate><Button Content="{Binding}" Command="{Binding DataContext.SelectLeadTimeCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" HorizontalContentAlignment="Left" Margin="0,0,0,8" /></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                                                            <TextBlock Text="Custom lead time" Style="{StaticResource MutedText}" Margin="0,4,0,4" />
                                                            <TextBox Text="{Binding CustomLeadTime, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                                                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                                <Button Content="Clear" Command="{Binding ClearLeadTimeCommand}" Margin="0,0,6,0" Height="32" />
                                                                <Button Grid.Column="1" Content="Use Custom" Command="{Binding SelectLeadTimeCommand}" CommandParameter="" Margin="6,0,6,0" Height="32" />
                                                                <Button Grid.Column="2" Content="Done" Command="{Binding CloseLeadTimeDropdownCommand}" Margin="6,0,0,0" Height="32" />
                                                            </Grid>
                                                        </StackPanel>
                                                    </Border>
                                                </Popup>
                                            </Grid>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Button Content="Clear" Command="{Binding ClearCurrentFireplaceCommand}" Height="36" Margin="0,0,6,0" />
                                                <Button Grid.Column="1" Content="{Binding AddFireplaceButtonText}" Command="{Binding AddFireplaceCommand}" Style="{StaticResource PrimaryButton}" Height="36" Margin="6,0,0,0" />
                                            </Grid>
                                            <ItemsControl ItemsSource="{Binding Fireplaces}"><ItemsControl.ItemTemplate><DataTemplate><Border Background="{DynamicResource FlareChipBrush}" BorderBrush="{DynamicResource FlareChipBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="8,6" Margin="0,0,0,8"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{Binding FireplaceLabel}" FontWeight="SemiBold" TextWrapping="Wrap" /><TextBlock Text="{Binding LeadTimeLine}" Style="{StaticResource MutedText}" /><TextBlock Text="{Binding FeaturesLine}" Style="{StaticResource MutedText}" TextWrapping="Wrap" /><TextBlock Text="{Binding ClassicMediaLine}" Style="{StaticResource MutedText}" TextWrapping="Wrap" /><TextBlock Text="{Binding PremiumMediaLine}" Style="{StaticResource MutedText}" TextWrapping="Wrap" /></StackPanel><Button Grid.Column="1" Content="×" Command="{Binding DataContext.RemoveFireplaceCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Width="28" Padding="0" Margin="8,0,0,0" /></Grid></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                                        </StackPanel>
                                    </Border>
                            </StackPanel>

                        

                        <Button Grid.Row="2" Content="Preview Quote" Command="{Binding NextToPreviewCommand}" Style="{StaticResource PrimaryButton}" Height="40" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>












