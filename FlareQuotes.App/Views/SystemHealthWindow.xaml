<Window x:Class="FlareQuotes.App.Views.SystemHealthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="System Health"
        Width="760"
        Height="620"
        MinWidth="680"
        MinHeight="520"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="{DynamicResource WindowSurfaceBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="54"
                            ResizeBorderThickness="7"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border CornerRadius="0"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            Background="{DynamicResource WindowSurfaceBrush}"
            ClipToBounds="False">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="54" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="70" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource WindowTitleBarBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="18,0,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="30" Height="30" CornerRadius="8" Background="{DynamicResource SurfaceRaisedBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1" Margin="0,0,11,0">
                            <TextBlock Text="&#xE9D9;" FontFamily="Segoe Fluent Icons" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="System health" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Style="{StaticResource CloseCaptionButton}" shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="CloseButton_Click"
                            ToolTip="Close"
                            AutomationProperties.Name="Close system health">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe Fluent Icons" FontSize="12" />
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="{DynamicResource WindowHeaderBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="24,20">
                <StackPanel>
                    <TextBlock Text="System readiness check" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Text="Confirming that files and integrations required by the quote workflow are available."
                               Style="{StaticResource MutedText}"
                               Margin="0,5,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{DynamicResource WindowWorkspaceBrush}"
                          Padding="24,18,16,18">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource GlassCard}" Padding="14" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="34" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border Width="26" Height="26" CornerRadius="13" Background="{DynamicResource SurfaceSubtleBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1" VerticalAlignment="Top">
                                        <TextBlock Text="{Binding Icon}"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource FlareAccentBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding State}" Value="Warning">
                                                            <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding State}" Value="Error">
                                                            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="6,0,18,0">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" />
                                        <TextBlock Text="{Binding Detail}" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,4,0,0" />
                                    </StackPanel>

                                    <Border Grid.Column="2"
                                            CornerRadius="999"
                                            Background="{DynamicResource SurfaceSubtleBrush}"
                                            BorderBrush="{DynamicResource DividerBrush}"
                                            BorderThickness="1"
                                            Padding="11,6"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding StateText}" FontWeight="SemiBold" FontSize="11">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessMutedBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding State}" Value="Warning">
                                                            <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding State}" Value="Error">
                                                            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Row="3"
                    Background="{DynamicResource WindowTitleBarBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="20,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="Open logs" Width="110" Margin="0,0,10,0" Click="OpenLogsButton_Click" />
                    <Button Content="Done" Width="110" Style="{StaticResource PrimaryButton}" Click="CloseButton_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
