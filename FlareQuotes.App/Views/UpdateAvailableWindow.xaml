<Window x:Class="FlareQuotes.App.Views.UpdateAvailableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Update Available"
        Width="620"
        Height="430"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="{DynamicResource WindowSurfaceBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="54"
                            ResizeBorderThickness="7"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border CornerRadius="0"
            Background="{DynamicResource WindowSurfaceBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            ClipToBounds="False">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="54" />
                <RowDefinition Height="*" />
                <RowDefinition Height="58" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource WindowTitleBarBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="18,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="30" Height="30" CornerRadius="8" Background="{DynamicResource SurfaceRaisedBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1" Margin="0,0,11,0">
                            <Viewbox Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"><Path Data="M8,1.5 A6.5,6.5 0 1 1 2.2,5 M2.2,1.8 L2.2,5 L5.4,5 M8,4 L8,8.2 L11,10" Stroke="{DynamicResource FlareAccentBrush}" StrokeThickness="1.45" StrokeStartLineCap="Round" StrokeEndLineCap="Round" /></Viewbox>
                        </Border>
                        <TextBlock Text="Application update" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Height="28"
                            MinWidth="76"
                            Padding="12,0"
                            CornerRadius="0"
                            Background="{DynamicResource SurfaceSubtleBrush}"
                            BorderBrush="{DynamicResource DividerBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="VersionBadgeText"
                                   Text="Update"
                                   Foreground="{DynamicResource FlareAccentBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Background="{DynamicResource WindowWorkspaceBrush}" Margin="0">
                <Grid Margin="26,22">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Update available" FontSize="23" FontWeight="SemiBold" />
                        <TextBlock x:Name="VersionLineText"
                                   Text="A new version is ready to install."
                                   Style="{StaticResource MutedText}"
                                   FontSize="13"
                                   Margin="0,5,0,0" />
                    </StackPanel>

                    <Border Grid.Row="2" Style="{StaticResource GlassCard}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="24" Height="24" CornerRadius="12" Background="{DynamicResource SurfaceSubtleBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1" VerticalAlignment="Top">
                                <TextBlock Text="i" Foreground="{DynamicResource FlareAccentBrush}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="What changed" FontSize="14" FontWeight="SemiBold" Margin="0,1,0,8" />
                                <ScrollViewer MaxHeight="140" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,6,0">
                                    <TextBlock x:Name="ReleaseNotesText"
                                               Style="{StaticResource MutedText}"
                                               FontSize="12.5"
                                               TextWrapping="Wrap"
                                               LineHeight="19" />
                                </ScrollViewer>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="3"
                               Text="The installer is downloaded only from the verified Flare release channel and is checked before it opens."
                               Style="{StaticResource MutedText}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Margin="0,14,0,0" />
                </Grid>
            </Grid>

            <Border Grid.Row="2"
                    Background="{DynamicResource WindowTitleBarBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="20,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="LaterButton" Content="Later" Width="96" Height="34" Margin="0,0,10,0" Click="LaterButton_Click" />
                    <Button x:Name="InstallButton" Content="Install update" Width="138" Height="34" Style="{StaticResource PrimaryButton}" Click="InstallButton_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
