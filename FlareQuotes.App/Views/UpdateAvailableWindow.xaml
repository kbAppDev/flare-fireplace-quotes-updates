<Window x:Class="FlareQuotes.App.Views.UpdateAvailableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Available"
        Width="620"
        Height="430"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <SolidColorBrush x:Key="TextMainBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#B8C5D6" />
        <SolidColorBrush x:Key="TextSoftBrush" Color="#8FA2B8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#99CC00" />
        <SolidColorBrush x:Key="AccentTextBrush" Color="#14210A" />
        <SolidColorBrush x:Key="ButtonBrush" Color="#263546" />
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#31445A" />

        <LinearGradientBrush x:Key="WindowBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F20B1220" Offset="0" />
            <GradientStop Color="#EE111B2B" Offset="0.52" />
            <GradientStop Color="#F4070B13" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="PanelBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#B9253548" Offset="0" />
            <GradientStop Color="#9B1A2838" Offset="0.55" />
            <GradientStop Color="#80131E2C" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BadgeBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#334E6B" Offset="0" />
            <GradientStop Color="#1F3146" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="MinWidth" Value="146" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="Background" Value="{StaticResource ButtonBrush}" />
            <Setter Property="BorderBrush" Value="#3A516A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15"
                                RenderTransformOrigin="0.5,0.5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{StaticResource ButtonHoverBrush}" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#4E6A89" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryDialogButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource AccentTextBrush}" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="MinWidth" Value="168" />
        </Style>
        <!-- Flare update modal scrollbar style -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#4B647F" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Width="8" Background="Transparent">
                            <Border Width="8"
                                    CornerRadius="4"
                                    Background="#162334"
                                    Opacity="0.65" />

                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True"
                                   Margin="0">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Opacity="0"
                                                  Focusable="False" />
                                </Track.DecreaseRepeatButton>

                                <Track.Thumb>
                                    <Thumb MinHeight="34">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border Width="8"
                                                        CornerRadius="4"
                                                        Background="#4B647F"
                                                        BorderBrush="#6D8BAA"
                                                        BorderThickness="1"
                                                        Opacity="0.92" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>

                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Opacity="0"
                                                  Focusable="False" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#6F8EAD" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- End Flare update modal scrollbar style -->
    </Window.Resources>

    <Border CornerRadius="26"
            Background="{StaticResource WindowBrush}"
            BorderBrush="#334963"
            BorderThickness="1"
            ClipToBounds="True"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="34"
                              ShadowDepth="10"
                              Direction="270"
                              Opacity="0.48"
                              Color="Black" />
        </Border.Effect>

        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="46"
                        Height="46"
                        CornerRadius="16"
                        Background="#223248"
                        BorderBrush="#3A516A"
                        BorderThickness="1">
                    <TextBlock Text="↧"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="27"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,-2,0,0" />
                </Border>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="Update Available"
                               FontSize="25"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextMainBrush}" />
                    <TextBlock x:Name="VersionLineText"
                               Text="A new version is ready to install."
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="14"
                               Margin="0,4,0,0" />
                </StackPanel>

                <Border Grid.Column="3"
                        Height="34"
                        MinWidth="88"
                        Padding="14,0"
                        CornerRadius="17"
                        Background="{StaticResource BadgeBrush}"
                        BorderBrush="#435C78"
                        BorderThickness="1"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="VersionBadgeText"
                               Text="v"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    CornerRadius="20"
                    Padding="18"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="#334963"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="34" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="32"
                            Height="32"
                            CornerRadius="16"
                            Background="#243447"
                            BorderBrush="#3A516A"
                            BorderThickness="1"
                            VerticalAlignment="Top">
                        <TextBlock Text="i"
                                   FontSize="17"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="What changed"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMainBrush}"
                                   Margin="0,0,0,8" />

                        <ScrollViewer MaxHeight="128"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="0,0,4,0">
                            <TextBlock x:Name="ReleaseNotesText"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="14"
                                       TextWrapping="Wrap"
                                       LineHeight="20" />
                        </ScrollViewer>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Grid.Row="3"
                       Text="Install now to get the latest quote app improvements. You can choose Later and keep working."
                       Foreground="{StaticResource TextSoftBrush}"
                       FontSize="13"
                       TextWrapping="Wrap"
                       VerticalAlignment="Top"
                       Margin="0,16,0,0" />

            <Grid Grid.Row="4" HorizontalAlignment="Right">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        x:Name="LaterButton"
                        Content="Later"
                        Style="{StaticResource DialogButtonStyle}"
                        Click="LaterButton_Click" />

                <Button Grid.Column="2"
                        x:Name="InstallButton"
                        Content="Install Update"
                        Style="{StaticResource PrimaryDialogButtonStyle}"
                        Click="InstallButton_Click" />
            </Grid>
        </Grid>
    </Border>
</Window>

