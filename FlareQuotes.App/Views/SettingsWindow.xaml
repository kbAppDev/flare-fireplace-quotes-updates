<Window x:Class="FlareQuotes.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="760"
        Height="820"
        MinWidth="700"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="SettingsWindow_MouseDown">

    
    <Window.Resources>
        <Style x:Key="SettingsComboBoxItemStyle" TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="{DynamicResource FlareTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="ItemBorder"
                                CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                Margin="4,2">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource GlassButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource FlareAccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Foreground" Value="{DynamicResource FlareTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource GlassInputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource FlareBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <Border x:Name="OuterBorder"
                                    CornerRadius="10"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" />

                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="14,0,38,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left" />

                            <Path HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Margin="0,0,14,0"
                                  Fill="{DynamicResource FlareMutedTextBrush}"
                                  Data="M 0 0 L 5 5 L 10 0 Z" />

                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press" />

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade">
                                <Border Background="{DynamicResource FlareDarkBrush}"
                                        BorderBrush="{DynamicResource FlareBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="4"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="18"
                                                          ShadowDepth="8"
                                                          Opacity="0.35"
                                                          Color="Black" />
                                    </Border.Effect>
                                    <ScrollViewer>
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{DynamicResource FlareAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{DynamicResource FlareAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
<Border CornerRadius="22"
            Background="{DynamicResource FlareDarkBrush}"
            BorderBrush="{DynamicResource FlareBorderBrush}"
            BorderThickness="1.5"
            Margin="16">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30"
                              ShadowDepth="10"
                              Opacity="0.45"
                              Direction="270"
                              Color="Black" />
        </Border.Effect>

        <Grid Margin="26">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,18">
                <TextBlock Text="Settings"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource FlareTextBrush}" />
                <TextBlock Text="Update contact info, Gmail settings, pricing files, update behavior, and lead times."
                           Style="{StaticResource MutedText}"
                           Margin="0,5,0,0"
                           TextWrapping="Wrap" />
                <Border BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource FlareBorderBrush}"
                        Margin="0,16,0,0" />
            </StackPanel>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="0,0,8,0">
                <StackPanel>

                    <Border Style="{StaticResource GlassCard}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="PDF Contact Information"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource FlareTextBrush}"
                                       Margin="0,0,0,12" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Sales Email" Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <TextBox x:Name="SalesEmailBox" Grid.Row="1" Grid.Column="0" Margin="0,0,0,10" />

                                <TextBlock Text="Sales Phone" Grid.Row="0" Grid.Column="2" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <TextBox x:Name="SalesPhoneBox" Grid.Row="1" Grid.Column="2" Margin="0,0,0,10" />

                                <TextBlock Text="Website" Grid.Row="2" Grid.Column="0" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <TextBox x:Name="WebsiteBox" Grid.Row="3" Grid.Column="0" Margin="0,0,0,2" />

                                <TextBlock Text="Consultation URL" Grid.Row="2" Grid.Column="2" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <TextBox x:Name="ConsultationUrlBox" Grid.Row="3" Grid.Column="2" Margin="0,0,0,2" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource GlassCard}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Gmail &amp; HubSpot"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource FlareTextBrush}"
                                       Margin="0,0,0,12" />

                            <TextBlock Text="HubSpot BCC Address" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <TextBox x:Name="HubSpotBccBox" Margin="0,0,0,10" />

                            <TextBlock Text="Gmail Credentials File" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="110" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="GmailCredentialsPathBox" Grid.Column="0" />
                                <Button Grid.Column="2" Content="Browse" Click="BrowseGmailCredentials_Click" />
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <CheckBox x:Name="UseGmailSignatureCheckBox"
                                          Grid.Column="0"
                                          Content="Use Gmail signature"
                                          Margin="0,2,0,0" />

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Email Send Mode" FontWeight="SemiBold" Margin="0,0,0,4" />
                                    <ComboBox x:Name="EmailSendModeBox" SelectedIndex="0" Style="{StaticResource SettingsComboBoxStyle}" ItemContainerStyle="{StaticResource SettingsComboBoxItemStyle}">
                                        <ComboBoxItem Content="draft" />
                                        <ComboBoxItem Content="send" />
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource GlassCard}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Pricing &amp; Updates"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource FlareTextBrush}"
                                       Margin="0,0,0,12" />

                            <TextBlock Text="Pricing Workbook" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="110" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="PricingFileBox" Grid.Column="0" />
                                <Button Grid.Column="2" Content="Browse" Click="BrowsePricingFile_Click" />
                            </Grid>

                            <TextBlock Text="Update Manifest URL" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <TextBox x:Name="UpdateManifestUrlBox" Margin="0,0,0,10" />

                            <CheckBox x:Name="CheckUpdatesOnStartupCheckBox"
                                      Content="Check for app updates automatically on startup"
                                      Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                                        <Border Style="{StaticResource GlassCard}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Quote Recall"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource FlareTextBrush}"
                                       Margin="0,0,0,8" />

                            <TextBlock Text="Number of completed quotes to keep in the Recall Last Quote list."
                                       Style="{StaticResource MutedText}"
                                       Margin="0,0,0,8"
                                       TextWrapping="Wrap" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="RecallQuoteHistoryLimitBox"
                                         Width="120"
                                         HorizontalAlignment="Left"
                                         Text="5" />

                                <TextBlock Grid.Column="1"
                                           Text="Recommended: 5. Allowed range: 1 to 20."
                                           Style="{StaticResource MutedText}"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0"
                                           TextWrapping="Wrap" />
                            </Grid>
                        </StackPanel>
                    </Border>
<Border Style="{StaticResource GlassCard}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Lead Time Presets"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource FlareTextBrush}"
                                       Margin="0,0,0,8" />

                            <TextBlock Text="One preset per line. These show in the Lead Time dropdown."
                                       Style="{StaticResource MutedText}"
                                       Margin="0,0,0,8"
                                       TextWrapping="Wrap" />

                            <TextBox x:Name="LeadTimePresetsBox"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="150" />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="140" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="SettingsStatusText"
                           Grid.Column="0"
                           Style="{StaticResource MutedText}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />

                <Button Grid.Column="1"
                        Content="Cancel"
                        Click="CancelButton_Click"
                        Height="38" />

                <Button Grid.Column="3"
                        Content="Save Settings"
                        Click="SaveButton_Click"
                        Style="{StaticResource PrimaryButton}"
                        Height="38" />
            </Grid>
        </Grid>
    </Border>
</Window>

