<Window x:Class="FlareQuotes.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Flare Fireplaces - Quotes" Width="1480" Height="920" MinWidth="1180" MinHeight="760"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        MouseLeftButtonDown="Window_MouseDown" Background="Transparent" AllowsTransparency="True" UseLayoutRounding="True" SnapsToDevicePixels="True">

    <Border CornerRadius="14"
            Background="{DynamicResource WindowSurfaceBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            ClipToBounds="True">
        <Grid Background="{DynamicResource WindowSurfaceBrush}" PreviewMouseDown="Root_PreviewMouseDown">
            <Grid.RowDefinitions>
                <RowDefinition Height="54" />
                <RowDefinition Height="84" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Compact Windows title bar -->
            <Border Grid.Row="0"
                    CornerRadius="13,13,0,0"
                    Background="{DynamicResource WindowTitleBarBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="18,0,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="30" Height="30" CornerRadius="8" Background="{DynamicResource FlareAccentBrush}" Margin="0,0,11,0">
                            <TextBlock Text="F" Foreground="{DynamicResource FlareAccentTextBrush}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <Image x:Name="HeaderLogoImage"
                               Source="/Assets/header_logo-dark.png"
                               Width="142"
                               Height="28"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               SnapsToDevicePixels="False"
                               UseLayoutRounding="False" />
                        <Border Width="1" Height="18" Background="{DynamicResource DividerBrush}" Margin="11,0" />
                        <TextBlock Text="Quotes" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                        <TextBlock x:Name="AppVersionText" Text="v1.5.0" Style="{StaticResource MutedText}" FontSize="11" Margin="7,1,0,0" VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding GmailStatusText}" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,10,0" Visibility="Collapsed" />
                        <TextBlock x:Name="ThemeLabelText" Text="Dark Mode" Visibility="Collapsed" />
                        <ToggleButton x:Name="ThemeToggleButton"
                                      Style="{StaticResource ModeToggleStyle}"
                                      ToolTip="Switch light or dark theme"
                                      AutomationProperties.Name="Switch light or dark theme"
                                      IsChecked="True"
                                      Checked="ThemeToggleButton_Checked"
                                      Unchecked="ThemeToggleButton_Unchecked">
                            <TextBlock Text="&#xE706;" FontFamily="Segoe Fluent Icons" FontSize="16" />
                        </ToggleButton>
                        <Button Style="{StaticResource IconButton}"
                                Click="SettingsButton_Click"
                                ToolTip="Settings"
                                AutomationProperties.Name="Open settings">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons" FontSize="16" />
                        </Button>
                        <Button Style="{StaticResource CaptionButton}" Click="MinimizeButton_Click" ToolTip="Minimize" AutomationProperties.Name="Minimize">
                            <TextBlock Text="&#xE921;" FontFamily="Segoe Fluent Icons" FontSize="10" />
                        </Button>
                        <Button Style="{StaticResource CaptionButton}" Click="MaximizeButton_Click" ToolTip="Maximize or restore" AutomationProperties.Name="Maximize or restore">
                            <TextBlock Text="&#xE922;" FontFamily="Segoe Fluent Icons" FontSize="10" />
                        </Button>
                        <Button Style="{StaticResource CloseCaptionButton}" Click="CloseButton_Click" ToolTip="Close" AutomationProperties.Name="Close">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe Fluent Icons" FontSize="12" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Workflow navigation and high-frequency commands -->
            <Border Grid.Row="1"
                    Background="{DynamicResource WindowHeaderBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="24,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="265" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="270" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Create quote" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Text="Prepare and review the customer request." Style="{StaticResource MutedText}" FontSize="12" Margin="0,4,0,0" />
                    </StackPanel>

                    <Grid Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="42" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="42" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="42" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="28" Height="28" CornerRadius="14" Margin="0,0,8,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceSubtleBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WorkflowStage}" Value="Review">
                                                <Setter Property="Background" Value="{DynamicResource FlareAccentBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource FlareAccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding WorkflowStage}" Value="Review">
                                                    <Setter Property="Foreground" Value="{DynamicResource FlareAccentTextBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                            <TextBlock Text="Build quote" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" />
                        </StackPanel>
                        <Border Grid.Column="1" Height="1" Background="{DynamicResource DividerBrush}" Margin="10,0" />

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="28" Height="28" CornerRadius="14" Margin="0,0,8,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceSubtleBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WorkflowStage}" Value="PdfPreview">
                                                <Setter Property="Background" Value="{DynamicResource FlareAccentBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource FlareAccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="2" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding WorkflowStage}" Value="PdfPreview">
                                                    <Setter Property="Foreground" Value="{DynamicResource FlareAccentTextBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                            <TextBlock Text="Preview" VerticalAlignment="Center" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WorkflowStage}" Value="PdfPreview">
                                                <Setter Property="Foreground" Value="{DynamicResource FlareTextBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <Border Grid.Column="3" Height="1" Background="{DynamicResource DividerBrush}" Margin="10,0" />

                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="28" Height="28" CornerRadius="14" Margin="0,0,8,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceSubtleBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WorkflowStage}" Value="SpecLinks">
                                                <Setter Property="Background" Value="{DynamicResource FlareAccentBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource FlareAccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="3" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding WorkflowStage}" Value="SpecLinks">
                                                    <Setter Property="Foreground" Value="{DynamicResource FlareAccentTextBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                            <TextBlock Text="Verify links" VerticalAlignment="Center" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WorkflowStage}" Value="SpecLinks">
                                                <Setter Property="Foreground" Value="{DynamicResource FlareTextBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <Border Grid.Column="5" Height="1" Background="{DynamicResource DividerBrush}" Margin="10,0" />

                        <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="28" Height="28" CornerRadius="14" Margin="0,0,8,0" Background="{DynamicResource SurfaceSubtleBrush}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1">
                                <TextBlock Text="4" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" />
                            </Border>
                            <TextBlock Text="Gmail draft" VerticalAlignment="Center" FontSize="12" Style="{StaticResource MutedText}" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="RecallLastQuoteButton"
                                Style="{StaticResource QuietButton}"
                                Content="Recent quotes"
                                Click="RecallLastQuoteButton_Click"
                                IsEnabled="{Binding CanRecallLastQuote}"
                                Margin="0,0,8,0">
                            <Button.ContextMenu>
                                <ContextMenu ItemsSource="{Binding PlacementTarget.DataContext.RecentQuoteHistory, RelativeSource={RelativeSource Self}}"
                                             Placement="Bottom"
                                             MinWidth="260">
                                    <ContextMenu.ItemContainerStyle>
                                        <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                            <Setter Property="Header" Value="{Binding DisplayName}" />
                                            <Setter Property="Command" Value="{Binding PlacementTarget.DataContext.RecallQuoteCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
                                            <Setter Property="CommandParameter" Value="{Binding}" />
                                        </Style>
                                    </ContextMenu.ItemContainerStyle>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                        <Button Content="New quote" Command="{Binding ClearCommand}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="16" Background="{DynamicResource WindowWorkspaceBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.0*" />
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="1.0*" />
                </Grid.ColumnDefinitions>

                <!-- One visual workspace spans the review and selection columns. -->
                <Border Grid.Column="1"
                        Grid.ColumnSpan="2"
                        Margin="4,0,0,0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding WorkflowStage}" Value="PdfPreview">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding WorkflowStage}" Value="SpecLinks">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                                <!-- StageResponsivePasteCard -->
                <Border Grid.Column="0" Margin="0,0,4,0">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource GlassCard}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding WorkflowStage}" Value="PdfPreview">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding WorkflowStage}" Value="SpecLinks">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Text="STEP 1" Style="{StaticResource EyebrowText}" />
                            <TextBlock Text="Customer request" FontSize="17" FontWeight="SemiBold" Margin="0,5,0,0" />
                            <TextBlock Text="Paste the email or request details below." Style="{StaticResource MutedText}" Margin="0,4,0,14" />
                        </StackPanel>
                        <TextBox Grid.Row="1" Text="{Binding RawRequest, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                        <Grid Grid.Row="2" Margin="0,10,0,0" HorizontalAlignment="Stretch">
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="0" />
    </Grid.ColumnDefinitions>

    <Button Grid.Column="0" Margin="0,0,5,0" MinWidth="0" Height="36" HorizontalAlignment="Stretch" VerticalAlignment="Center" Content="Clear" Command="{Binding ClearCommand}" />

    <Button Grid.Column="1" Margin="5,0,0,0" MinWidth="0" Height="36" HorizontalAlignment="Stretch" VerticalAlignment="Center" Content="Auto-fill" Command="{Binding AutoFillCommand}" Style="{StaticResource PrimaryButton}" />


</Grid>
                    </Grid>
                </Border>

                                <!-- StageResponsiveWorkflowCard -->
                <Border Margin="4,0,4,0">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource GlassCard}">
                            <Setter Property="Grid.Column" Value="1" />
                            <Setter Property="Grid.ColumnSpan" Value="1" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
                            <Setter Property="BorderThickness" Value="0,0,1,0" />
                            <Setter Property="CornerRadius" Value="0" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding WorkflowStage}" Value="PdfPreview">
                                    <Setter Property="Grid.Column" Value="0" />
                                    <Setter Property="Grid.ColumnSpan" Value="3" />
                                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Setter Property="CornerRadius" Value="10" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding WorkflowStage}" Value="SpecLinks">
                                    <Setter Property="Grid.Column" Value="0" />
                                    <Setter Property="Grid.ColumnSpan" Value="3" />
                                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Setter Property="CornerRadius" Value="10" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WorkflowStage}" Value="Review">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0">
                                <TextBlock Text="QUOTE WORKSPACE" Style="{StaticResource EyebrowText}" />
                                <TextBlock Text="Review quote details" FontSize="17" FontWeight="SemiBold" Margin="0,5,0,0" />
                                <TextBlock Text="Confirm the customer and fireplace information before previewing." Style="{StaticResource MutedText}" Margin="0,4,0,14" />
                            </StackPanel>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
                                <StackPanel>
                                    <UniformGrid Columns="2" Rows="0">
                                        <StackPanel Margin="0,0,10,12"><TextBlock Text="Project" /><TextBox Text="{Binding ProjectName}" /></StackPanel>
                                        <StackPanel Margin="0,0,0,12"><TextBlock Text="Name" /><TextBox Text="{Binding ClientName}" /></StackPanel>
                                        <StackPanel Margin="0,0,10,12"><TextBlock Text="Email" /><TextBox Text="{Binding Email}" /></StackPanel>
                                        <StackPanel Margin="0,0,0,12"><TextBlock Text="Phone" /><TextBox Text="{Binding Phone}" /></StackPanel>
                                        <StackPanel Margin="0,0,10,12"><TextBlock Text="Project Address" /><TextBox Text="{Binding Postal}" /></StackPanel>
                                        <StackPanel Margin="0,0,0,12"><TextBlock Text="Install Date" /><TextBox Text="{Binding InstallDate}" /></StackPanel>
                                        <StackPanel Margin="0,0,10,12"><TextBlock Text="Model" /><TextBox Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                        <StackPanel Margin="0,0,0,12"><TextBlock Text="Size" /><TextBox Text="{Binding Size, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                        <StackPanel Margin="0,0,10,12"><TextBlock Text="Glass Height" /><TextBox Text="{Binding GlassHeight, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                        <StackPanel Margin="0,0,0,12"><TextBlock Text="Location" /><TextBox Text="{Binding FireplaceLocation, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                    </UniformGrid>
                            <!-- ReviewStageStatusPills -->
                            <Border Background="{DynamicResource FlareCardAltBrush}" BorderBrush="{DynamicResource FlareBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="10" Margin="0,12,0,0">
                                <ItemsControl ItemsSource="{Binding StatusCards}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="3" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource FlareCardBrush}" CornerRadius="11" Padding="9,7" Margin="0,0,8,8" Height="58">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="22" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="11.5" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding Detail}" Style="{StaticResource MutedText}" FontSize="11" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" Margin="0,2,0,0" />
                                                    </StackPanel>

                                                    <Ellipse Grid.Column="1" Width="13" Height="13" Fill="{Binding IndicatorFill}" Stroke="{DynamicResource FlareBorderBrush}" StrokeThickness="1" ToolTip="{Binding StatusText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>


                                    

                                    
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                                                                            <!-- FullWidthPreviewStage -->
<Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WorkflowStage}" Value="PdfPreview">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Preview Quote" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="Review the generated quote PDF. Use Open Generated PDF if the embedded preview cannot render the file." Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                            </StackPanel>

                            <Border Grid.Row="2" Background="{DynamicResource FlareCardAltBrush}" CornerRadius="14" Padding="10" BorderBrush="{DynamicResource FlareBorderBrush}" BorderThickness="1">
                                <Grid>
                                    <Border Background="White" CornerRadius="8" ClipToBounds="True">
                                        <Grid>
                                            <ContentControl x:Name="PdfPreviewHost" />
                                            <Border x:Name="PdfPreviewFallback" Background="{DynamicResource FlareCardBrush}" BorderBrush="{DynamicResource FlareBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="18">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock Text="Quote PDF generated." FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                                    <TextBlock Text="Live preview loads after the PDF is generated." Style="{StaticResource MutedText}" TextAlignment="Center" Margin="0,8,0,0" />
                                                    <TextBlock Text="Use Open Generated PDF if the preview component is unavailable." Style="{StaticResource MutedText}" TextAlignment="Center" Margin="0,4,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- FullWidthPreviewActionFooter -->
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="140" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding GeneratedPdfSummary}" Style="{StaticResource MutedText}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,12,0" />
                                <Button Grid.Column="1" Content="Back" Command="{Binding BackToReviewCommand}" Height="40" />
                                <Button Grid.Column="3" Content="Open Generated PDF" Command="{Binding OpenGeneratedPdfCommand}" Height="40" Padding="16,0" />
                                <Button Grid.Column="5" Content="Verify URLs" Command="{Binding NextToSpecLinksCommand}" Style="{StaticResource PrimaryButton}" Height="40" />
                            </Grid>
                        </Grid>

                                                                            <!-- FullWidthSpecLinksStage -->
<Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WorkflowStage}" Value="SpecLinks">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Verify URLs" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="Review the product/spec URLs before creating the Gmail draft." Style="{StaticResource MutedText}" Margin="0,4,0,0"  Visibility="Collapsed" />
                            </StackPanel>

                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,10,0,10">
        <ItemsControl ItemsSource="{Binding UrlVerificationFireplaces}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Command="{Binding DataContext.SelectUrlVerificationFireplaceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            Margin="0,6,14,6"
                            MinWidth="205">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="OverridesDefaultStyle" Value="True" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
