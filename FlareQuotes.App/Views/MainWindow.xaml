<Window x:Class="FlareQuotes.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Flare Fireplaces - Quotes" Width="1480" Height="920" MinWidth="1180" MinHeight="760"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource WindowSurfaceBrush}"
        AllowsTransparency="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="56"
                            ResizeBorderThickness="7"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="WindowFrame"
            CornerRadius="0"
            Background="{DynamicResource WindowSurfaceBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="0"
            ClipToBounds="False">
        <Grid Background="{DynamicResource WindowSurfaceBrush}" PreviewMouseDown="Root_PreviewMouseDown">
            <Grid.RowDefinitions>
                <RowDefinition Height="56" />
                <RowDefinition Height="76" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Compact Windows title bar -->
            <Border Grid.Row="0"
                    CornerRadius="0"
                    Background="{DynamicResource WindowTitleBarBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="22,0,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image x:Name="HeaderLogoImage"
                               Source="/Assets/header_logo-dark.png"
                               Width="150"
                               Height="30"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               SnapsToDevicePixels="False"
                               UseLayoutRounding="False" />
                        <Border Width="1" Height="18" Background="{DynamicResource DividerBrush}" Margin="11,0" />
                        <TextBlock Text="Quotes" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                        <TextBlock x:Name="AppVersionText" Text="v1.6.0" Style="{StaticResource MutedText}" FontSize="11" Margin="7,1,0,0" VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock Text="{Binding GmailStatusText}" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,10,0" Visibility="Collapsed" />
                        <TextBlock x:Name="ThemeLabelText" Text="Dark Mode" Visibility="Collapsed" />
                        <ToggleButton x:Name="ThemeToggleButton"
                                      Style="{StaticResource ModeToggleStyle}"
                                      ToolTip="Switch light or dark theme"
                                      AutomationProperties.Name="Switch light or dark theme"
                                      IsChecked="True"
                                      Checked="ThemeToggleButton_Checked"
                                      Unchecked="ThemeToggleButton_Unchecked">
                            <Grid Width="18" Height="18">
                                <Path Data="{StaticResource MoonIconGeometry}"
                                      Stroke="{DynamicResource FlareTextBrush}"
                                      StrokeThickness="1.5"
                                      StrokeLineJoin="Round"
                                      Stretch="Uniform">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                                <Path Data="{StaticResource SunIconGeometry}"
                                      Stroke="{DynamicResource FlareTextBrush}"
                                      StrokeThickness="1.35"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Stretch="Uniform">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Grid>
                        </ToggleButton>
                        <Button Style="{StaticResource IconButton}"
                                Click="SettingsButton_Click"
                                ToolTip="Settings"
                                AutomationProperties.Name="Open settings">
                            <Viewbox Width="18" Height="18">
                                <Path Data="{StaticResource SettingsIconGeometry}" Stroke="{DynamicResource FlareTextBrush}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource CaptionButton}" Click="MinimizeButton_Click" ToolTip="Minimize" AutomationProperties.Name="Minimize">
                            <Viewbox Width="12" Height="12"><Path Data="{StaticResource MinimizeIconGeometry}" Stroke="{DynamicResource FlareTextBrush}" StrokeThickness="1.25" /></Viewbox>
                        </Button>
                        <Button Style="{StaticResource CaptionButton}" Click="MaximizeButton_Click" ToolTip="Maximize or restore" AutomationProperties.Name="Maximize or restore">
                            <Viewbox Width="12" Height="12"><Path Data="{StaticResource MaximizeIconGeometry}" Stroke="{DynamicResource FlareTextBrush}" StrokeThickness="1.25" /></Viewbox>
                        </Button>
                        <Button Style="{StaticResource CloseCaptionButton}" Click="CloseButton_Click" ToolTip="Close" AutomationProperties.Name="Close">
                            <Viewbox Width="12" Height="12"><Path Data="{StaticResource CloseIconGeometry}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.35" StrokeStartLineCap="Round" /></Viewbox>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Workflow navigation and high-frequency commands -->
            <Border Grid.Row="1"
                    Background="{DynamicResource WindowHeaderBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="26,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="245" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="250" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Quote workspace" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock Text="Build a complete, presentation-ready fireplace quote." Style="{StaticResource MutedText}" FontSize="12" Margin="0,4,0,0" />
                    </StackPanel>

                    <Grid Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="42" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="42" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="42" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="28" Height="30" CornerRadius="14" Margin="0,0,8,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceSubtleBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WorkflowStage}" Value="Review">
                                                <Setter Property="Background" Value="{DynamicResource FlareAccentBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource FlareAccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding WorkflowStage}" Value="Review">
                                                    <Setter Property="Foreground" Value="{DynamicResource FlareAccentTextBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                            <TextBlock Text="Build quote" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" />
                        </StackPanel>
                        <Border Grid.Column="1" Height="1" Background="{DynamicResource DividerBrush}" Margin="10,0" />

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="28" Height="30" CornerRadius="14" Margin="0,0,8,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceSubtleBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WorkflowStage}" Value="PdfPreview">
                                                <Setter Property="Background" Value="{DynamicResource FlareAccentBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource FlareAccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="2" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding WorkflowStage}" Value="PdfPreview">
                                                    <Setter Property="Foreground" Value="{DynamicResource FlareAccentTextBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                            <TextBlock Text="Preview" VerticalAlignment="Center" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WorkflowStage}" Value="PdfPreview">
                                                <Setter Property="Foreground" Value="{DynamicResource FlareTextBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <Border Grid.Column="3" Height="1" Background="{DynamicResource DividerBrush}" Margin="10,0" />

                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="28" Height="30" CornerRadius="14" Margin="0,0,8,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource SurfaceSubtleBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WorkflowStage}" Value="SpecLinks">
                                                <Setter Property="Background" Value="{DynamicResource FlareAccentBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource FlareAccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="3" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding WorkflowStage}" Value="SpecLinks">
                                                    <Setter Property="Foreground" Value="{DynamicResource FlareAccentTextBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                            <TextBlock Text="Verify links" VerticalAlignment="Center" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WorkflowStage}" Value="SpecLinks">
                                                <Setter Property="Foreground" Value="{DynamicResource FlareTextBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <Border Grid.Column="5" Height="1" Background="{DynamicResource DividerBrush}" Margin="10,0" />

                        <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="28" Height="30" CornerRadius="14" Margin="0,0,8,0" Background="{DynamicResource SurfaceSubtleBrush}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1">
                                <TextBlock Text="4" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" />
                            </Border>
                            <TextBlock Text="Gmail draft" VerticalAlignment="Center" FontSize="12" Style="{StaticResource MutedText}" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="RecallLastQuoteButton"
                                Style="{StaticResource QuietButton}"
                                Click="RecallLastQuoteButton_Click"
                                IsEnabled="{Binding CanRecallLastQuote}"
                                Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="14" Height="14" Margin="0,0,7,0"><Path Data="{StaticResource RecentIconGeometry}" Stroke="{DynamicResource FlareMutedTextBrush}" StrokeThickness="1.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" /></Viewbox>
                                <TextBlock Text="Recent quotes" VerticalAlignment="Center" />
                            </StackPanel>
                            <Button.ContextMenu>
                                <ContextMenu ItemsSource="{Binding PlacementTarget.DataContext.RecentQuoteHistory, RelativeSource={RelativeSource Self}}"
                                             Placement="Bottom"
                                             MinWidth="260">
                                    <ContextMenu.ItemContainerStyle>
                                        <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                            <Setter Property="Header" Value="{Binding DisplayName}" />
                                            <Setter Property="Command" Value="{Binding PlacementTarget.DataContext.RecallQuoteCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
                                            <Setter Property="CommandParameter" Value="{Binding}" />
                                        </Style>
                                    </ContextMenu.ItemContainerStyle>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                        <Button Command="{Binding ClearCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="14" Height="14" Margin="0,0,7,0"><Path Data="{StaticResource PlusIconGeometry}" Stroke="{DynamicResource FlareTextBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" /></Viewbox>
                                <TextBlock Text="New quote" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="16" Background="{DynamicResource WindowWorkspaceBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="400" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                                <!-- StageResponsivePasteCard -->
                <Border x:Name="RequestPane" Grid.Column="0" Margin="0">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource GlassCard}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Setter Property="Padding" Value="0" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding WorkflowStage}" Value="PdfPreview">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding WorkflowStage}" Value="SpecLinks">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Border BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1" Padding="18,15,18,13">
                            <StackPanel>
                                <TextBlock Text="STEP 1" Style="{StaticResource EyebrowText}" />
                                <TextBlock Text="Customer request" FontSize="17" FontWeight="SemiBold" Margin="0,5,0,0" />
                                <TextBlock Text="Paste the email or request details below." Style="{StaticResource MutedText}" Margin="0,3,0,0" />
                            </StackPanel>
                        </Border>
                        <Grid Grid.Row="1" Margin="18,14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <TextBlock Text="Request content" FontSize="11.5" FontWeight="SemiBold" />
                                <TextBlock Text="Ctrl + V to paste" Style="{StaticResource MutedText}" FontSize="11" HorizontalAlignment="Right" />
                            </Grid>
                            <TextBox Grid.Row="2" Text="{Binding RawRequest, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Padding="14,12" />
                        </Grid>
                        <Border Grid.Row="2" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,0" Padding="18,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MutedText}" FontSize="11" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="0,0,12,0" />
                                <Button Grid.Column="1" Content="Clear" Command="{Binding ClearCommand}" MinWidth="64" Height="34" />
                                <Button Grid.Column="3" Content="Auto-fill" Command="{Binding AutoFillCommand}" Style="{StaticResource PrimaryButton}" MinWidth="84" Height="34" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                                <!-- StageResponsiveWorkflowCard -->
                <Border x:Name="QuoteWorkspacePane" Margin="0">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource GlassCard}">
                            <Setter Property="Grid.Column" Value="2" />
                            <Setter Property="Grid.ColumnSpan" Value="1" />
                            <Setter Property="Padding" Value="0" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding WorkflowStage}" Value="PdfPreview">
                                    <Setter Property="Grid.Column" Value="0" />
                                    <Setter Property="Grid.ColumnSpan" Value="3" />
                                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Setter Property="CornerRadius" Value="10" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding WorkflowStage}" Value="SpecLinks">
                                    <Setter Property="Grid.Column" Value="0" />
                                    <Setter Property="Grid.ColumnSpan" Value="3" />
                                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Setter Property="CornerRadius" Value="10" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WorkflowStage}" Value="Review">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1" Padding="18,14">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="QUOTE WORKSPACE" Style="{StaticResource EyebrowText}" />
                                        <TextBlock Text="Review quote details" FontSize="17" FontWeight="SemiBold" Margin="0,5,0,0" />
                                        <TextBlock Text="Confirm the customer and fireplace information before previewing." Style="{StaticResource MutedText}" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Center" Background="{DynamicResource SurfaceSubtleBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1" CornerRadius="16" Padding="10,5">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="7" Height="7" Fill="{DynamicResource FlareAccentBrush}" Margin="0,0,7,0" />
                                            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MutedText}" FontSize="11" MaxWidth="260" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="18,14,10,14">
                                <StackPanel>
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="12" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Column="0"><TextBlock Text="Project" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5" /><TextBox Text="{Binding ProjectName}" /></StackPanel>
                                        <StackPanel Grid.Column="2"><TextBlock Text="Customer" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5" /><TextBox Text="{Binding ClientName}" /></StackPanel>
                                        <StackPanel Grid.Column="4"><TextBlock Text="Email" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5" /><TextBox Text="{Binding Email}" /></StackPanel>
                                        <StackPanel Grid.Row="2" Grid.Column="0"><TextBlock Text="Phone" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5" /><TextBox Text="{Binding Phone}" /></StackPanel>
                                        <StackPanel Grid.Row="2" Grid.Column="2"><TextBlock Text="Project address" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5" /><TextBox Text="{Binding Postal}" /></StackPanel>
                                        <StackPanel Grid.Row="2" Grid.Column="4"><TextBlock Text="Install target" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5" /><TextBox Text="{Binding InstallDate}" /></StackPanel>
                                    </Grid>

                                    <Border BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,0" Padding="0,16,0,0">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <StackPanel>
                                                    <TextBlock Text="Fireplaces" FontSize="15" FontWeight="SemiBold" />
                                                    <TextBlock Text="Build the current fireplace, then add another only when the quote needs one." Style="{StaticResource MutedText}" FontSize="11" Margin="0,3,0,0" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <Button Content="Clear current" Command="{Binding ClearCurrentFireplaceCommand}" Style="{StaticResource QuietButton}" Height="32" Margin="0,0,6,0" />
                                                    <Button Content="{Binding AddFireplaceButtonText}" Command="{Binding AddFireplaceCommand}" Height="32" />
                                                </StackPanel>
                                            </Grid>

                                            <Border Background="{DynamicResource SurfaceSubtleBrush}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="14">
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,12">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                        <Border Width="30" Height="30" CornerRadius="8" Background="#1E2B12" BorderBrush="#4E6B25" BorderThickness="1" Margin="0,0,10,0">
                                                            <Path Data="M15,3 C16,7 21,8 21,14 C21,19 18,23 12,23 C7,23 4,19 4,14 C4,10 7,7 10,4 C10,8 12,10 14,11 C15,9 15,6 15,3 Z" Fill="{DynamicResource FlareAccentBrush}" Stretch="Uniform" Margin="6" />
                                                        </Border>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="Current fireplace" FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding CurrentFireplaceLabel}" Style="{StaticResource MutedText}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                    </Grid>

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="1.15*" /><ColumnDefinition Width="12" />
                                                            <ColumnDefinition Width="0.8*" /><ColumnDefinition Width="12" />
                                                            <ColumnDefinition Width="0.8*" /><ColumnDefinition Width="12" />
                                                            <ColumnDefinition Width="1.1*" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0"><TextBlock Text="Model" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5" /><TextBox Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                                        <StackPanel Grid.Column="2"><TextBlock Text="Size" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5" /><TextBox Text="{Binding Size, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                                        <StackPanel Grid.Column="4"><TextBlock Text="Glass height" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5" /><TextBox Text="{Binding GlassHeight, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                                        <StackPanel Grid.Column="6"><TextBlock Text="Location" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5" /><TextBox Text="{Binding FireplaceLocation, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                                    </Grid>

                                                    <Grid Margin="0,12,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="1.15*" /><ColumnDefinition Width="12" />
                                                            <ColumnDefinition Width="*" /><ColumnDefinition Width="12" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Grid.Column="0">
