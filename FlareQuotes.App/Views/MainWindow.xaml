                                                                    <Border Width="320" Background="{DynamicResource DropdownPopupBrush}" BorderBrush="{DynamicResource DropdownOptionBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,4,0,0"><StackPanel><TextBox Text="{Binding PremiumMediaSearch, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" ToolTip="Search premium media" /><ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="180"><ItemsControl ItemsSource="{Binding FilteredPremiumMediaOptions}"><ItemsControl.ItemTemplate><DataTemplate><Button Command="{Binding DataContext.TogglePremiumMediaCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" HorizontalContentAlignment="Left" Margin="0,0,0,6"><TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" /></Button></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></ScrollViewer><Grid Margin="0,4,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="8" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Button Content="Clear" Command="{Binding ClearPremiumMediaCommand}" Height="32" /><Button Grid.Column="2" Content="Done" Command="{Binding ClosePremiumMediaDropdownCommand}" Height="32" /></Grid></StackPanel></Border>
