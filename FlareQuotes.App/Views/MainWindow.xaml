                                </Border>

                                <Image Grid.Row="1"
       Source="{Binding ImagePath}"
       Height="66"
       Width="150"
       Stretch="Uniform"
       HorizontalAlignment="Center"
       VerticalAlignment="Center"
       Margin="0,0,0,4"
       Opacity="0.98"
       RenderOptions.BitmapScalingMode="HighQuality"
       SnapsToDevicePixels="True" />

                                <TextBlock Grid.Row="2" Text="{Binding ModelCode}" HorizontalAlignment="Center" FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource FlareTextBrush}" Margin="0,7,0,0" />
                                <TextBlock Grid.Row="3" Text="{Binding StyleLabel}" HorizontalAlignment="Center" FontSize="13" Foreground="{DynamicResource FlareMutedTextBrush}" Margin="0,4,0,0" />

                                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                                    <TextBlock Text="{Binding StatusGlyph}" FontSize="15" FontWeight="Bold" Margin="0,0,7,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource FlareAccentBrush}" />
