<Window x:Class="FlareQuotes.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Flare Fireplaces - Quotes" Width="1420" Height="880" MinWidth="1100" MinHeight="720"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        MouseLeftButtonDown="Window_MouseDown" Background="Transparent" AllowsTransparency="True" UseLayoutRounding="True" SnapsToDevicePixels="True">
    
    <Border CornerRadius="20" Background="{DynamicResource GlassBackgroundBrush}" BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1.5" Margin="0" ClipToBounds="True">
        
        
        <Grid Background="Transparent" PreviewMouseDown="Root_PreviewMouseDown">
            <Grid.RowDefinitions>
                <RowDefinition Height="76" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="18,18,0,0" Background="{DynamicResource GlassHeaderBrush}" BorderBrush="{DynamicResource GlassCardBorderBrush}" BorderThickness="0,0,0,1" Padding="22,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image x:Name="HeaderLogoImage" Source="/Assets/header_logo-dark.png" Width="210" Stretch="Uniform" Margin="0,0,18,0" RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="False" UseLayoutRounding="False" />
                        <StackPanel>
                            <TextBlock Text="Flare Fireplaces - Quotes" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource FlareTextBrush}" Visibility="Collapsed" />
                            <TextBlock x:Name="AppVersionText" Text="v1.4.9" Style="{StaticResource MutedText}" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="14,0,0,0">
                        <TextBlock Text="{Binding GmailStatusText}" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,18,0"  Visibility="Collapsed" />
                        
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,6,14,6">
                            <TextBlock x:Name="ThemeLabelText" Text="Dark Mode" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold" Style="{StaticResource MutedText}"/>
                            <ToggleButton x:Name="ThemeToggleButton" Style="{StaticResource ModeToggleStyle}" IsChecked="True" Checked="ThemeToggleButton_Checked" Unchecked="ThemeToggleButton_Unchecked" />
                        </StackPanel>
                        
                        <Button Content="Settings" Width="104" Click="SettingsButton_Click" />
                        <Border Width="1" Background="{DynamicResource GlassBorderBrush}" Margin="16,4" />
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Width="14" Height="14" Margin="0,0,8,0" Click="MinimizeButton_Click" Cursor="Hand" ToolTip="Minimize"><Button.Template><ControlTemplate TargetType="Button"><Border Background="#FFBD2E" CornerRadius="7"/></ControlTemplate></Button.Template></Button>
                            <Button Width="14" Height="14" Margin="0,0,8,0" Click="MaximizeButton_Click" Cursor="Hand" ToolTip="Maximize"><Button.Template><ControlTemplate TargetType="Button"><Border Background="#27C93F" CornerRadius="7"/></ControlTemplate></Button.Template></Button>
                            <Button Width="14" Height="14" Click="CloseButton_Click" Cursor="Hand" ToolTip="Close"><Button.Template><ControlTemplate TargetType="Button"><Border Background="#FF5F56" CornerRadius="7"/></ControlTemplate></Button.Template></Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="1.55*" />
                    <ColumnDefinition Width="1.0*" />
                </Grid.ColumnDefinitions>

                                <!-- StageResponsivePasteCard -->
                <Border Grid.Column="0" Margin="0,0,4,0">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource GlassCard}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding WorkflowStage}" Value="PdfPreview">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding WorkflowStage}" Value="SpecLinks">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Text="Request" FontSize="20" FontWeight="SemiBold" />
                            <TextBlock Text="Paste the customer request, then auto-fill review fields." Style="{StaticResource MutedText}" Margin="0,4,0,14" />
                        </StackPanel>
                        <TextBox Grid.Row="1" Text="{Binding RawRequest, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                        <Grid Grid.Row="2" Margin="0,10,0,0" HorizontalAlignment="Stretch">
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Button Grid.Column="0" Margin="0,0,5,0" MinWidth="0" Height="34" Padding="4,0" FontSize="11" HorizontalAlignment="Stretch" VerticalAlignment="Center" Content="Auto-Fill" Command="{Binding AutoFillCommand}" Style="{StaticResource PrimaryButton}" />

    <Button Grid.Column="1" Margin="5,0,5,0" MinWidth="0" Height="34" Padding="4,0" FontSize="11" HorizontalAlignment="Stretch" VerticalAlignment="Center" Content="New Quote" Command="{Binding ClearCommand}" />

    <Button Grid.Column="2" Margin="5,0,0,0" MinWidth="0" Height="34" Padding="4,0" FontSize="9.5" HorizontalAlignment="Stretch" VerticalAlignment="Center" x:Name="RecallLastQuoteButton"
                                    Content="Recall Last Quote"
                                    Click="RecallLastQuoteButton_Click"
                                    IsEnabled="{Binding CanRecallLastQuote}">
                                <Button.ContextMenu>
                                    <ContextMenu ItemsSource="{Binding PlacementTarget.DataContext.RecentQuoteHistory, RelativeSource={RelativeSource Self}}" Placement="Top" MinWidth="245" Background="Transparent" BorderThickness="0" Padding="0" SnapsToDevicePixels="True">
                    <ContextMenu.Style>
                        <Style TargetType="{x:Type ContextMenu}">
                            <Setter Property="OverridesDefaultStyle" Value="True" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                                        <Border CornerRadius="18"
                                                Background="{DynamicResource DropdownPopupBrush}"
                                                BorderBrush="{DynamicResource DropdownOptionBorderBrush}"
                                                BorderThickness="1"
                                                Padding="8"
                                                SnapsToDevicePixels="True">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#000000"
                                                                  BlurRadius="28"
                                                                  ShadowDepth="10"
                                                                  Direction="270"
                                                                  Opacity="0.42" />
                                            </Border.Effect>

                                            <StackPanel>
                                                <TextBlock Text="Recall Last Quote"
                                                           Foreground="{DynamicResource DropdownTextBrush}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Margin="6,2,6,6" />
                                                <Border Height="1"
                                                        Background="#9A5B7088"
                                                        Opacity="0.75"
                                                        Margin="4,0,4,6" />
                                                <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ContextMenu.Style>
                                        <ContextMenu.ItemContainerStyle>
                                                                    <Style TargetType="{x:Type MenuItem}">
                            <Setter Property="Header" Value="{Binding DisplayName}" />
                            <Setter Property="Command" Value="{Binding PlacementTarget.DataContext.RecallQuoteCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
                            <Setter Property="CommandParameter" Value="{Binding}" />

                            <Setter Property="Foreground" Value="#F4F7FA" />
                            <Setter Property="FontSize" Value="12" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Padding" Value="12,8" />
                            <Setter Property="MinHeight" Value="40" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="OverridesDefaultStyle" Value="True" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type MenuItem}">
                                        <Border x:Name="ItemRoot"
                                                CornerRadius="13"
                                                Margin="2"
                                                Padding="{TemplateBinding Padding}"
                                                Background="{DynamicResource DropdownOptionBrush}"
                                                BorderBrush="{DynamicResource DropdownOptionBorderBrush}"
                                                BorderThickness="1"
                                                SnapsToDevicePixels="True">
                                            <Border.RenderTransform>
                                                <TranslateTransform Y="0" />
                                            </Border.RenderTransform>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Ellipse x:Name="RecallDot"
                                                         Width="8"
                                                         Height="8"
                                                         Fill="#99CC00"
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,10,0">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect Color="#99CC00"
                                                                          BlurRadius="10"
                                                                          ShadowDepth="0"
                                                                          Opacity="0.42" />
                                                    </Ellipse.Effect>
                                                </Ellipse>

                                                <ContentPresenter Grid.Column="1"
                                                                  ContentSource="Header"
                                                                  RecognizesAccessKey="True"
                                                                  VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>

                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter TargetName="ItemRoot" Property="Background" Value="#334257" />
                                                <Setter TargetName="ItemRoot" Property="BorderBrush" Value="#99CC00" />
                                                <Setter TargetName="ItemRoot" Property="RenderTransform">
                                                    <Setter.Value>
                                                        <TranslateTransform Y="-1" />
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="ItemRoot" Property="Opacity" Value="0.45" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                                        </ContextMenu.ItemContainerStyle>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
</Grid>
                    </Grid>
                </Border>

                                <!-- StageResponsiveWorkflowCard -->
                <Border Margin="4,0,4,0">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource GlassCard}">
                            <Setter Property="Grid.Column" Value="1" />
                            <Setter Property="Grid.ColumnSpan" Value="1" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding WorkflowStage}" Value="PdfPreview">
                                    <Setter Property="Grid.Column" Value="0" />
                                    <Setter Property="Grid.ColumnSpan" Value="3" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding WorkflowStage}" Value="SpecLinks">
                                    <Setter Property="Grid.Column" Value="0" />
                                    <Setter Property="Grid.ColumnSpan" Value="3" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WorkflowStage}" Value="Review">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Review" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="Review fields, selections, and fireplaces before previewing the quote." Style="{StaticResource MutedText}" Margin="0,4,0,14" />
                            </StackPanel>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
                                <StackPanel>
                                    <UniformGrid Columns="2" Rows="0">
                                        <StackPanel Margin="0,0,10,12"><TextBlock Text="Project" /><TextBox Text="{Binding ProjectName}" /></StackPanel>
                                        <StackPanel Margin="0,0,0,12"><TextBlock Text="Name" /><TextBox Text="{Binding ClientName}" /></StackPanel>
                                        <StackPanel Margin="0,0,10,12"><TextBlock Text="Email" /><TextBox Text="{Binding Email}" /></StackPanel>
                                        <StackPanel Margin="0,0,0,12"><TextBlock Text="Phone" /><TextBox Text="{Binding Phone}" /></StackPanel>
                                        <StackPanel Margin="0,0,10,12"><TextBlock Text="Project Address" /><TextBox Text="{Binding Postal}" /></StackPanel>
                                        <StackPanel Margin="0,0,0,12"><TextBlock Text="Install Date" /><TextBox Text="{Binding InstallDate}" /></StackPanel>
                                        <StackPanel Margin="0,0,10,12"><TextBlock Text="Model" /><TextBox Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                        <StackPanel Margin="0,0,0,12"><TextBlock Text="Size" /><TextBox Text="{Binding Size, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                        <StackPanel Margin="0,0,10,12"><TextBlock Text="Glass Height" /><TextBox Text="{Binding GlassHeight, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                        <StackPanel Margin="0,0,0,12"><TextBlock Text="Location" /><TextBox Text="{Binding FireplaceLocation, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                                    </UniformGrid>
                            <!-- ReviewStageStatusPills -->
                            <Border Background="{DynamicResource FlareCardAltBrush}" BorderBrush="{DynamicResource FlareBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="10" Margin="0,12,0,0">
                                <ItemsControl ItemsSource="{Binding StatusCards}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="3" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource FlareCardBrush}" CornerRadius="11" Padding="9,7" Margin="0,0,8,8" Height="58">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="22" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="11.5" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding Detail}" Style="{StaticResource MutedText}" FontSize="10.5" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" Margin="0,2,0,0" />
                                                    </StackPanel>

                                                    <Ellipse Grid.Column="1" Width="13" Height="13" Fill="{Binding IndicatorFill}" Stroke="{DynamicResource FlareBorderBrush}" StrokeThickness="1" ToolTip="{Binding StatusText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>


                                    

                                    
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                                                                            <!-- FullWidthPreviewStage -->
<Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WorkflowStage}" Value="PdfPreview">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Preview Quote" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="Review the generated quote PDF. Use Open Generated PDF if the embedded preview cannot render the file." Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                            </StackPanel>

                            <Border Grid.Row="2" Background="{DynamicResource FlareCardAltBrush}" CornerRadius="14" Padding="10" BorderBrush="{DynamicResource FlareBorderBrush}" BorderThickness="1">
                                <Grid>
                                    <Border Background="White" CornerRadius="8" ClipToBounds="True">
                                        <Grid>
                                            <ContentControl x:Name="PdfPreviewHost" />
                                            <Border x:Name="PdfPreviewFallback" Background="{DynamicResource FlareCardBrush}" BorderBrush="{DynamicResource FlareBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="18">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock Text="Quote PDF generated." FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                                    <TextBlock Text="Live preview loads after the PDF is generated." Style="{StaticResource MutedText}" TextAlignment="Center" Margin="0,8,0,0" />
                                                    <TextBlock Text="Use Open Generated PDF if the preview component is unavailable." Style="{StaticResource MutedText}" TextAlignment="Center" Margin="0,4,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- FullWidthPreviewActionFooter -->
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="140" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding GeneratedPdfSummary}" Style="{StaticResource MutedText}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,12,0" />
                                <Button Grid.Column="1" Content="Back" Command="{Binding BackToReviewCommand}" Height="40" />
                                <Button Grid.Column="3" Content="Open Generated PDF" Command="{Binding OpenGeneratedPdfCommand}" Height="40" Padding="16,0" />
                                <Button Grid.Column="5" Content="Verify URLs" Command="{Binding NextToSpecLinksCommand}" Style="{StaticResource PrimaryButton}" Height="40" />
                            </Grid>
                        </Grid>

                                                                            <!-- FullWidthSpecLinksStage -->
<Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WorkflowStage}" Value="SpecLinks">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Verify URLs" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="Review the product/spec URLs before creating the Gmail draft." Style="{StaticResource MutedText}" Margin="0,4,0,0"  Visibility="Collapsed" />
                            </StackPanel>

                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,10,0,10">
        <ItemsControl ItemsSource="{Binding UrlVerificationFireplaces}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Command="{Binding DataContext.SelectUrlVerificationFireplaceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            Margin="0,6,14,6"
                            MinWidth="205">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="OverridesDefaultStyle" Value="True" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                              RecognizesAccessKey="True" />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <Border CornerRadius="18" Padding="14" Width="198" MinHeight="174" Background="#DE293544" BorderBrush="{DynamicResource DropdownOptionBorderBrush}" BorderThickness="1" RenderTransformOrigin="0.5,0.5">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Opacity" Value="0.92" />
                                    <Setter Property="Margin" Value="0,0,0,0" />
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <TranslateTransform Y="0" />
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="#000000" BlurRadius="0" ShadowDepth="0" Opacity="0" />
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BorderBrush" Value="#99CC00" />
                                            <Setter Property="BorderThickness" Value="2" />
                                            <Setter Property="Opacity" Value="1" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                            <Setter Property="Opacity" Value="1" />
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <TranslateTransform Y="-4" />
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Color="#000000" BlurRadius="18" ShadowDepth="5" Direction="270" Opacity="0.24" />
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="70" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Width="28" Height="28" CornerRadius="14" HorizontalAlignment="Left" Background="#3366CC">
                                    <TextBlock Text="{Binding Index}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="White" />
                                </Border>

                                <Image Grid.Row="1"
       Source="{Binding ImagePath}"
       Height="66"
       Width="150"
       Stretch="Uniform"
       HorizontalAlignment="Center"
       VerticalAlignment="Center"
       Margin="0,0,0,4"
       Opacity="0.98"
       RenderOptions.BitmapScalingMode="HighQuality"
       SnapsToDevicePixels="True" />

                                <TextBlock Grid.Row="2" Text="{Binding ModelCode}" HorizontalAlignment="Center" FontSize="17" FontWeight="SemiBold" Foreground="White" Margin="0,7,0,0" />
                                <TextBlock Grid.Row="3" Text="{Binding StyleLabel}" HorizontalAlignment="Center" FontSize="13" Foreground="#CCD5DF" Margin="0,4,0,0" />

                                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                                    <TextBlock Text="{Binding StatusGlyph}" FontSize="15" FontWeight="Bold" Margin="0,0,7,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#99CC00" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsValid}" Value="False">
                                                        <Setter Property="Foreground" Value="#FF5A5F" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding StatusText}" FontSize="13">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#DCE7F3" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsValid}" Value="False">
                                                        <Setter Property="Foreground" Value="#FF8A8E" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>

    <Border CornerRadius="18" Padding="12" Background="#D8202C3A" BorderBrush="{DynamicResource DropdownOptionBorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Margin="0,0,0,8">
                <TextBlock Text="{Binding SelectedUrlVerificationSummary}" Foreground="White" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="Review only the URLs for the selected fireplace." Foreground="#AEB9C6" FontSize="11" Margin="0,2,0,0" />
            </StackPanel>

            <Border Grid.Row="1" CornerRadius="12" BorderBrush="{DynamicResource DropdownOptionBorderBrush}" BorderThickness="1" Background="#E61B2633">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32" />
                        <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Background="#DE243142">
                        <Grid.ColumnDefinitions>
