                                        <Border Width="30" Height="30" CornerRadius="15" BorderBrush="{DynamicResource FlareAccentBrush}" BorderThickness="2" Margin="0,0,10,0"><TextBlock Text="✓" Foreground="{DynamicResource FlareAccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" /></Border>
