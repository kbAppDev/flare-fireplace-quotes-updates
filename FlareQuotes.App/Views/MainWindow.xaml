                                                                                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}" VerticalAlignment="Center" Foreground="{DynamicResource DropdownTextBrush}" TextTrimming="CharacterEllipsis" HorizontalAlignment="Stretch" TextAlignment="Center" />
                                                                                </Grid>
                                                                            </Button>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </ScrollViewer>
                                                            <Grid Margin="0,5,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                                <Button Content="Clear" Command="{Binding ClearAdditionalClassicMediaCommand}" Margin="0,0,6,0" Height="32" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="{DynamicResource DropdownOptionBrush}" Foreground="{DynamicResource DropdownTextBrush}" BorderBrush="{DynamicResource DropdownOptionBorderBrush}" />
                                                                <Button Grid.Column="1" Content="Done" Command="{Binding CloseAdditionalClassicMediaDropdownCommand}" Margin="6,0,0,0" Height="32" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="{DynamicResource DropdownOptionBrush}" Foreground="{DynamicResource DropdownTextBrush}" BorderBrush="{DynamicResource DropdownOptionBorderBrush}" />
                                                            </Grid>
                                                        </StackPanel>
                                                    </Border>
                                                </Popup>
                                            </Grid>
                                            <ItemsControl ItemsSource="{Binding SelectedAdditionalClassicMedia}" Margin="0,0,0,8">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Tag="SelectedAdditionalClassicMediaChip"
                                                                Cursor="SizeAll"
                                                                ToolTip="Drag to reorder"
                                                                PreviewMouseLeftButtonDown="SelectedChip_PreviewMouseLeftButtonDown"
                                                                PreviewMouseMove="SelectedChip_PreviewMouseMove"
                                                                PreviewMouseLeftButtonUp="SelectedChip_PreviewMouseLeftButtonUp"
                                                                LostMouseCapture="SelectedChip_LostMouseCapture"
                                                                Background="{DynamicResource FlareChipBrush}"
                                                                BorderBrush="{DynamicResource FlareChipBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="14"
                                                                Padding="10,5"
                                                                Margin="0,0,8,8"
                                                                RenderTransformOrigin="0.5,0.5"
                                                                SnapsToDevicePixels="True">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Ellipse Width="8" Height="8" Fill="{DynamicResource FlareAccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                                <TextBlock Text="{Binding DisplayName}" />
                                                                <Button Content="×" Style="{StaticResource ChipRemoveButton}" ToolTip="Remove" AutomationProperties.Name="Remove"
                                                                        Command="{Binding DataContext.RemoveAdditionalClassicMediaCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Width="24"
                                                                        Padding="0"
                                                                        Margin="8,0,0,0" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Text="Premium Media" FontWeight="SemiBold" Margin="0,0,0,6" />
                                            <Grid Margin="0,0,0,8">
                                                <ToggleButton x:Name="PremiumMediaDropdownButton" Content="{Binding PremiumMediaDropdownButtonText}" IsChecked="{Binding IsPremiumMediaDropdownOpen, Mode=TwoWay}" HorizontalContentAlignment="Left" MinHeight="34" PreviewMouseLeftButtonDown="DropdownToggle_PreviewMouseLeftButtonDown" />
                                                <Popup AllowsTransparency="True" x:Name="PremiumMediaDropdownPopup" IsOpen="{Binding IsPremiumMediaDropdownOpen, Mode=TwoWay}" PlacementTarget="{Binding ElementName=PremiumMediaDropdownButton}" Placement="Bottom" StaysOpen="True" Opened="DropdownPopup_Opened">
                                                    <Border Width="{Binding ActualWidth, ElementName=PremiumMediaDropdownButton}" Background="{DynamicResource DropdownPopupBrush}" BorderBrush="{DynamicResource DropdownOptionBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="10" Margin="0,4,0,0">
                                                        <StackPanel>
                                                            <TextBox Text="{Binding PremiumMediaSearch, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" ToolTip="Search premium media"  Background="{DynamicResource DropdownInputBrush}" Foreground="{DynamicResource DropdownTextBrush}" CaretBrush="{DynamicResource DropdownTextBrush}" />
                                                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="120">
                                                                <ItemsControl ItemsSource="{Binding FilteredPremiumMediaOptions}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Button Command="{Binding DataContext.TogglePremiumMediaCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" HorizontalContentAlignment="Stretch" Margin="0,0,0,8" Padding="8,6" VerticalContentAlignment="Center" Background="{DynamicResource DropdownOptionBrush}" Foreground="{DynamicResource DropdownTextBrush}" BorderBrush="{DynamicResource DropdownOptionBorderBrush}">
                                                                                <Grid HorizontalAlignment="Stretch"><Grid.ColumnDefinitions><ColumnDefinition Width="24" /><ColumnDefinition Width="*" /><ColumnDefinition Width="24" /></Grid.ColumnDefinitions>
                                                                                    <Ellipse Width="9" Height="9" Fill="{DynamicResource FlareAccentBrush}" Stroke="Transparent" StrokeThickness="0" VerticalAlignment="Center" Grid.Column="0" HorizontalAlignment="Center">
                                                                                        <Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding IsSelected}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Ellipse.Style>
                                                                                    </Ellipse>
                                                                                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}" VerticalAlignment="Center" Foreground="{DynamicResource DropdownTextBrush}" TextTrimming="CharacterEllipsis" HorizontalAlignment="Stretch" TextAlignment="Center" />
                                                                                </Grid>
                                                                            </Button>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </ScrollViewer>
                                                            <Grid Margin="0,5,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                                <Button Content="Clear" Command="{Binding ClearPremiumMediaCommand}" Margin="0,0,6,0" Height="32" Background="{DynamicResource DropdownOptionBrush}" Foreground="{DynamicResource DropdownTextBrush}" BorderBrush="{DynamicResource DropdownOptionBorderBrush}" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
                                                                <Button Grid.Column="1" Content="Done" Command="{Binding ClosePremiumMediaDropdownCommand}" Margin="6,0,0,0" Height="32" Background="{DynamicResource DropdownOptionBrush}" Foreground="{DynamicResource DropdownTextBrush}" BorderBrush="{DynamicResource DropdownOptionBorderBrush}" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
                                                            </Grid>
                                                        </StackPanel>
                                                    </Border>
                                                </Popup>
                                            </Grid>
                                            <ItemsControl ItemsSource="{Binding SelectedPremiumMedia}" Margin="0,0,0,8"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><Border Tag="SelectedPremiumMediaChip" Cursor="SizeAll" ToolTip="Drag to reorder" PreviewMouseLeftButtonDown="SelectedChip_PreviewMouseLeftButtonDown" PreviewMouseMove="SelectedChip_PreviewMouseMove" PreviewMouseLeftButtonUp="SelectedChip_PreviewMouseLeftButtonUp" LostMouseCapture="SelectedChip_LostMouseCapture" Background="{DynamicResource FlareChipBrush}" BorderBrush="{DynamicResource FlareChipBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="10,5" Margin="0,0,8,8" RenderTransformOrigin="0.5,0.5" SnapsToDevicePixels="True"><StackPanel Orientation="Horizontal"><Ellipse Width="8" Height="8" Fill="{DynamicResource FlareAccentBrush}" VerticalAlignment="Center" Margin="0,0,8,0" /><TextBlock Text="{Binding DisplayName}" /><Button Content="×" Style="{StaticResource ChipRemoveButton}" ToolTip="Remove" AutomationProperties.Name="Remove" Command="{Binding DataContext.RemovePremiumMediaCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Width="24" Padding="0" Margin="8,0,0,0" /></StackPanel></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                                        </StackPanel>
                                    </Border>

<Border Background="{DynamicResource FlareCardAltBrush}" BorderBrush="{DynamicResource FlareBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="Fireplaces" FontSize="15" FontWeight="SemiBold" />
                                            <TextBlock Text="Lead time and multi-fireplace controls." Style="{StaticResource MutedText}" Margin="0,3,0,12" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding CurrentFireplaceLabel}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                            <TextBlock Text="Lead Time" FontWeight="SemiBold" Margin="0,8,0,6" />
                                            <Grid Margin="0,0,0,10">
                                                <ToggleButton x:Name="LeadTimeDropdownButton" Content="{Binding LeadTimeDropdownButtonText}" IsChecked="{Binding IsLeadTimeDropdownOpen, Mode=TwoWay}" HorizontalContentAlignment="Left" MinHeight="34" PreviewMouseLeftButtonDown="DropdownToggle_PreviewMouseLeftButtonDown" />
                                                <Popup AllowsTransparency="True" x:Name="LeadTimeDropdownPopup" IsOpen="{Binding IsLeadTimeDropdownOpen, Mode=TwoWay}" PlacementTarget="{Binding ElementName=LeadTimeDropdownButton}" Placement="Bottom" StaysOpen="True">
                                                    <Border Width="{Binding ActualWidth, ElementName=LeadTimeDropdownButton}" Background="{DynamicResource DropdownPopupBrush}" BorderBrush="{DynamicResource DropdownOptionBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="10" Margin="0,4,0,0">
                                                        <StackPanel>
                                                            <ItemsControl ItemsSource="{Binding LeadTimePresets}"><ItemsControl.ItemTemplate><DataTemplate><Button Content="{Binding}" Command="{Binding DataContext.SelectLeadTimeCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" HorizontalContentAlignment="Center" Margin="0,0,0,8" VerticalContentAlignment="Center" Background="{DynamicResource DropdownOptionBrush}" Foreground="{DynamicResource DropdownTextBrush}" BorderBrush="{DynamicResource DropdownOptionBorderBrush}" /></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                                                            <TextBlock Text="Custom lead time" Style="{StaticResource MutedText}" Margin="0,4,0,4" Foreground="{DynamicResource DropdownMutedTextBrush}" />
                                                            <TextBox Text="{Binding CustomLeadTime, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" Background="{DynamicResource DropdownInputBrush}" Foreground="{DynamicResource DropdownTextBrush}" CaretBrush="{DynamicResource DropdownTextBrush}" />
                                                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                                <Button Content="Clear" Command="{Binding ClearLeadTimeCommand}" Margin="0,0,6,0" Height="32" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="{DynamicResource DropdownOptionBrush}" Foreground="{DynamicResource DropdownTextBrush}" BorderBrush="{DynamicResource DropdownOptionBorderBrush}" />
                                                                <Button Grid.Column="1" Content="Use Custom" Command="{Binding SelectLeadTimeCommand}" CommandParameter="" Margin="6,0,6,0" Height="32" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="{DynamicResource DropdownOptionBrush}" Foreground="{DynamicResource DropdownTextBrush}" BorderBrush="{DynamicResource DropdownOptionBorderBrush}" />
                                                                <Button Grid.Column="2" Content="Done" Command="{Binding CloseLeadTimeDropdownCommand}" Margin="6,0,0,0" Height="32" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="{DynamicResource DropdownOptionBrush}" Foreground="{DynamicResource DropdownTextBrush}" BorderBrush="{DynamicResource DropdownOptionBorderBrush}" />
                                                            </Grid>
                                                        </StackPanel>
                                                    </Border>
                                                </Popup>
                                            </Grid>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Button Content="Clear" Command="{Binding ClearCurrentFireplaceCommand}" Height="34" Margin="0,0,6,0" />
                                                <Button Grid.Column="1" Content="{Binding AddFireplaceButtonText}" Command="{Binding AddFireplaceCommand}" Style="{StaticResource PrimaryButton}" Height="34" Margin="6,0,0,0" />
                                            </Grid>
                                            <ItemsControl ItemsSource="{Binding Fireplaces}"><ItemsControl.ItemTemplate><DataTemplate><Border Background="{DynamicResource FlareChipBrush}" BorderBrush="{DynamicResource FlareChipBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="8,6" Margin="0,0,0,8"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{Binding FireplaceLabel}" FontWeight="SemiBold" TextWrapping="Wrap" /><TextBlock Text="{Binding LeadTimeLine}" Style="{StaticResource MutedText}" /><TextBlock Text="{Binding FeaturesLine}" Style="{StaticResource MutedText}" TextWrapping="Wrap" /><TextBlock Text="{Binding ClassicMediaLine}" Style="{StaticResource MutedText}" TextWrapping="Wrap" /><TextBlock Text="{Binding PremiumMediaLine}" Style="{StaticResource MutedText}" TextWrapping="Wrap" /></StackPanel><Button Grid.Column="1" Content="×" Style="{StaticResource ChipRemoveButton}" ToolTip="Remove" AutomationProperties.Name="Remove" Command="{Binding DataContext.RemoveFireplaceCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Width="28" Padding="0" Margin="8,0,0,0" /></Grid></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                                        </StackPanel>
                                    </Border>
                        </StackPanel>
                        </ScrollViewer>

                        <Button Grid.Row="2" Content="Generate preview" Command="{Binding NextToPreviewCommand}" Style="{StaticResource PrimaryButton}" Height="40" Margin="0,10,0,0" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
