                                                        <ItemsControl ItemsSource="{Binding SelectedAdditionalClassicMedia}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><Border Tag="SelectedAdditionalClassicMediaChip" Cursor="SizeAll" PreviewMouseLeftButtonDown="SelectedChip_PreviewMouseLeftButtonDown" PreviewMouseMove="SelectedChip_PreviewMouseMove" PreviewMouseLeftButtonUp="SelectedChip_PreviewMouseLeftButtonUp" LostMouseCapture="SelectedChip_LostMouseCapture" Background="{DynamicResource FlareChipBrush}" BorderBrush="{DynamicResource FlareChipBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="10,4" Margin="0,0,7,7"><StackPanel Orientation="Horizontal"><TextBlock Text="{Binding DisplayName}" FontSize="11" /><Button Content="×" Style="{StaticResource ChipRemoveButton}" Command="{Binding DataContext.RemoveAdditionalClassicMediaCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Margin="5,0,-5,0" /></StackPanel></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                                                        <ItemsControl ItemsSource="{Binding SelectedPremiumMedia}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><Border Tag="SelectedPremiumMediaChip" Cursor="SizeAll" PreviewMouseLeftButtonDown="SelectedChip_PreviewMouseLeftButtonDown" PreviewMouseMove="SelectedChip_PreviewMouseMove" PreviewMouseLeftButtonUp="SelectedChip_PreviewMouseLeftButtonUp" LostMouseCapture="SelectedChip_LostMouseCapture" Background="{DynamicResource FlareChipBrush}" BorderBrush="{DynamicResource FlareChipBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="10,4" Margin="0,0,7,7"><StackPanel Orientation="Horizontal"><TextBlock Text="{Binding DisplayName}" FontSize="11" /><Button Content="×" Style="{StaticResource ChipRemoveButton}" Command="{Binding DataContext.RemovePremiumMediaCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Margin="5,0,-5,0" /></StackPanel></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
