                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="170" />
                                                <ColumnDefinition Width="560" />
                                                <ColumnDefinition Width="150" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding Item}" Foreground="{DynamicResource FlareTextBrush}" VerticalAlignment="Center" Margin="16,0,8,0" />
                                            <TextBox Grid.Column="1" Text="{Binding Url}" VerticalAlignment="Center" Margin="6,3" Padding="8,4" IsReadOnly="True" BorderThickness="0" Background="{DynamicResource FlareInputBrush}" Foreground="{DynamicResource FlareTextBrush}" />
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="14,0,0,0">
                                                <Grid Width="22" Height="22" Margin="0,0,8,0">
                                                    <Ellipse Width="13" Height="13" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="{DynamicResource FlareAccentBrush}" />
                                                                <Setter Property="Effect">
                                                                    <Setter.Value>
                                                                        <DropShadowEffect Color="#A6CE39" BlurRadius="15" ShadowDepth="0" Opacity="0.85" />
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsValid}" Value="False">
                                                                        <Setter Property="Fill" Value="{DynamicResource DangerBrush}" />
                                                                        <Setter Property="Effect">
                                                                            <Setter.Value>
                                                                                <DropShadowEffect Color="#FF5A5F" BlurRadius="15" ShadowDepth="0" Opacity="0.80" />
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                </Grid>
                                                <TextBlock Text="{Binding StatusText}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#DCE7F3" />
                                                            <Setter Property="VerticalAlignment" Value="Center" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsValid}" Value="False">
                                                                    <Setter Property="Foreground" Value="#FF8A8E" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <Border Grid.Row="2"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource DropdownOptionBorderBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="10,8">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="420" />
                                    <ColumnDefinition Width="110" />
                                </Grid.ColumnDefinitions>

                                <TextBox Text="{Binding ManualUrlToolName, UpdateSourceTrigger=PropertyChanged}"
                                         Height="32"
                                         Margin="0,0,8,0"
                                         Padding="8,4"
                                         ToolTip="Tool name, for example Installation Manual or Custom Link" />

                                <TextBox Grid.Column="1"
                                         Text="{Binding ManualUrlValue, UpdateSourceTrigger=PropertyChanged}"
                                         Height="32"
                                         Margin="0,0,8,0"
                                         Padding="8,4"
                                         ToolTip="Paste URL starting with https://" />

                                <Button Grid.Column="2"
                                        Content="Add URL"
                                        Command="{Binding AddManualUrlCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Height="32" />
                            </Grid>

                            <Border Margin="0,8,0,0"
                                    Padding="10,8"
                                    CornerRadius="10"
                                    Background="{DynamicResource SurfaceRaisedBrush}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding FireplacePhotoDisplayText}" Visibility="Visible"
                                               Foreground="{DynamicResource FlareTextBrush}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="6,0,14,0" />

                                    <Button Grid.Column="1"
                                            Content="Attach Fireplace Photos"
                                            Command="{Binding ChooseFireplacePhotoCommand}"
                                            MinWidth="170"
                                            Height="32"
                                            Padding="12,6" />
                                <StackPanel Grid.Column="2" Margin="12,0,0,0" MinWidth="260" MaxWidth="520">
                                    <TextBlock Text="{Binding FireplacePhotoSummary}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource FlareTextBrush}"
                                               TextWrapping="Wrap" />

                                    <ItemsControl ItemsSource="{Binding FireplacePhotoFileNames}"
                                                  Margin="0,6,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,4"
                                                        Padding="8,5"
                                                        CornerRadius="8"
                                                        Background="{DynamicResource SurfaceSubtleBrush}"
                                                        BorderBrush="{DynamicResource FlareAccentBrush}"
                                                        BorderThickness="1">
                                                    <TextBlock Text="{Binding}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource FlareMutedTextBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                    <Button Grid.Column="3"
                                            Content="Clear Photos"
                                            Command="{Binding ClearFireplacePhotoCommand}"
                                            MinWidth="104"
                                            Height="32"
                                            Padding="12,6" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</StackPanel>
                            </ScrollViewer>

                            <!-- FullWidthSpecLinksActionFooter -->
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="180" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Specific matched URLs are preferred. Yellow/fallback URLs should be checked before drafting." Style="{StaticResource MutedText}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,12,0" />
                                <Button Grid.Column="1" Content="Back to Preview" Command="{Binding BackToPreviewCommand}" Height="40" />
                                <Button Grid.Column="3" Content="Create Gmail Draft" Command="{Binding CreateDraftCommand}" Style="{StaticResource PrimaryButton}" Height="40" />
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </Border>
</Window>
