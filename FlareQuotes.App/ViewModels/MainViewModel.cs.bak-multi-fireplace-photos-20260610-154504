    private static readonly JsonSerializerOptions RecallHistoryJsonOptions = new()
    {
        PropertyNameCaseInsensitive = true,
        WriteIndented = true
    };

    private void LoadRecallHistory()
    {
        try
        {
            RecentQuoteHistory.Clear();

            if (!File.Exists(RecallHistoryPath))
            {
                CanRecallLastQuote = false;
                return;
            }

            var json = File.ReadAllText(RecallHistoryPath);
            var items = JsonSerializer.Deserialize<List<LastQuoteSnapshot>>(json, RecallHistoryJsonOptions) ?? [];

            foreach (var item in items
                         .Where(item => item is not null)
                         .OrderByDescending(item => item.CreatedAt)
                         .Take(RecallQuoteHistoryLimit))
            {
                RecentQuoteHistory.Add(item);
            }

            _lastCompletedQuoteSnapshot = RecentQuoteHistory.FirstOrDefault();
            CanRecallLastQuote = RecentQuoteHistory.Count > 0;
        }
        catch
        {
            RecentQuoteHistory.Clear();
            CanRecallLastQuote = false;
        }
    }

    private void SaveRecallHistory()
    {
        try
        {
            Directory.CreateDirectory(Path.GetDirectoryName(RecallHistoryPath)!);
            var items = RecentQuoteHistory.Take(RecallQuoteHistoryLimit).ToList();
            var json = JsonSerializer.Serialize(items, RecallHistoryJsonOptions);
            File.WriteAllText(RecallHistoryPath, json);
        }
        catch
        {
            // Recall history should never block quote creation.
        }
    }

    private void AddSnapshotToRecallHistory(LastQuoteSnapshot snapshot)
    {
        RecentQuoteHistory.Insert(0, snapshot);

        while (RecentQuoteHistory.Count > RecallQuoteHistoryLimit)
            RecentQuoteHistory.RemoveAt(RecentQuoteHistory.Count - 1);

        _lastCompletedQuoteSnapshot = RecentQuoteHistory.FirstOrDefault();
        CanRecallLastQuote = RecentQuoteHistory.Count > 0;
        SaveRecallHistory();
    }
