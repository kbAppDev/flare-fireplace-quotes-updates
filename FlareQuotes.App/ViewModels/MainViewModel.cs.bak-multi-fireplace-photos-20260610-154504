    private static bool MoveSelectionItem<T>(ObservableCollection<T> collection, T? source, T? target)
        where T : class
    {
        if (source is null || target is null || ReferenceEquals(source, target))
            return false;

        var oldIndex = collection.IndexOf(source);
        var newIndex = collection.IndexOf(target);

        if (oldIndex < 0 || newIndex < 0 || oldIndex == newIndex)
            return false;

        collection.Move(oldIndex, newIndex);
        return true;
    }


